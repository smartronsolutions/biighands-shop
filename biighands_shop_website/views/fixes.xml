<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

<record id="bhs_fix_shop_title" model="ir.ui.view">
  <field name="name">biighands.fix.theme_prime.shop_title</field>
  <field name="key">biighands_shop_website.fix_shop_title</field>
  <field name="inherit_id" ref="theme_prime.shop_layout"/>
  <field name="arch" type="xml">
    <xpath expr="//t[@t-set='additional_title']" position="replace">
      <t t-set="additional_title" t-value="category and category.name or 'Shop'"/>
    </xpath>
  </field>
</record>

</data>
</odoo>
