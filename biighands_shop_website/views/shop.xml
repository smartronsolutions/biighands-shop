<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

<!-- ═══════════════════════════════════════════════════════════
     BH SHOP — Custom shop page styling
     Inherits: theme_prime.shop_layout
               theme_prime.product_item_grid_1
               theme_prime.product_item_price
     CSS is loaded via assets (biighands_shop_website/static/src/css/shop.css)
     ═══════════════════════════════════════════════════════════ -->

<!-- ── 1. Shop layout: inject teal header banner above product grid ── -->
<template id="bh_shop_layout" inherit_id="theme_prime.shop_layout" name="BH Shop: Header + Teal">

    <!-- Target the oe_structure placeholder that sits at the very top of #wrap,
         just before o_wsale_container. 'before' puts our banner above it. -->
    <xpath expr="//div[@id='oe_structure_website_sale_products_1']" position="before">
        <div class="bh-shop-header">
            <div class="bh-shop-header-inner">
                <div>
                    <h1>Shop All Products</h1>
                    <p>Trade-quality products at unbeatable prices — fast delivery available</p>
                </div>
                <div class="bh-shop-header-pills">
                    <a href="/shop" class="bh-shop-header-pill">All Products</a>
                    <a href="/shop?order=price+asc" class="bh-shop-header-pill">Best Price</a>
                    <a href="/shop?order=create_date+desc" class="bh-shop-header-pill">New Arrivals</a>
                    <a href="/shop?order=website_sequence+asc" class="bh-shop-header-pill">Featured</a>
                </div>
            </div>
        </div>
    </xpath>

</template>


<!-- ── 2. Product card (Grid 1): sharper corners + content padding ── -->
<template id="bh_product_item_grid_1" inherit_id="theme_prime.product_item_grid_1" name="BH Shop: Product Card Grid 1">

    <!-- Remove default border class — CSS applies a styled border via .tp-product-wrapper -->
    <xpath expr="//div[hasclass('tp-product-wrapper')]" position="attributes">
        <attribute name="class">tp-product-wrapper h-100</attribute>
    </xpath>

    <!-- Content area: tighten padding to px-3 py-2 -->
    <xpath expr="//div[hasclass('tp-product-content')]" position="attributes">
        <attribute name="class">tp-product-content border-top px-3 py-2 position-relative text-center text-lg-start</attribute>
    </xpath>

</template>


<!-- ── 3. Price template: teal "% OFF" label ── -->
<template id="bh_product_item_price" inherit_id="theme_prime.product_item_price" name="BH Shop: Teal Price">

    <!-- Bold discount % badge -->
    <xpath expr="//small[hasclass('tp-discount-percentage')]" position="attributes">
        <attribute name="class">tp-discount-percentage d-none d-md-inline-block fw-bold</attribute>
    </xpath>

</template>

</data>
</odoo>
