<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

<!--
  Keep this view intentionally structure-free. The production Theme Prime
  shop template differs between releases, so all shop polish is applied
  through stable native classes in shop.css.
-->
<record id="bhs_shop_layout_branding" model="ir.ui.view">
  <field name="name">biighands_shop_website.shop_layout_branding</field>
  <field name="key">biighands_shop_website.shop_layout_branding</field>
  <field name="inherit_id" ref="website.layout"/>
  <field name="type">qweb</field>
  <field name="arch" type="xml">
    <xpath expr="//head" position="inside">
      <meta name="biighands-shop-theme" content="native-theme-prime"/>
    </xpath>
  </field>
</record>

</data>
</odoo>
