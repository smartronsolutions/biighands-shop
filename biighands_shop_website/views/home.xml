<!-- CAROUSEL + SCROLL ANIMATION + STATS COUNTER SCRIPT -->
<script type="text/javascript">
(function () {
  "use strict";

  /* ── CAROUSEL ── */
  var hero = document.getElementById("bhsHero");
  if (hero) {
    var slides = hero.querySelectorAll(".bhs-slide");
    var dots   = hero.querySelectorAll(".bhs-dot");
    var cur = 0, tmr;
    function show(n) {
      slides[cur].classList.remove("go"); dots[cur].classList.remove("on");
      cur = ((n % slides.length) + slides.length) % slides.length;
      slides[cur].classList.add("go"); dots[cur].classList.add("on");
    }
    function tick() { clearInterval(tmr); tmr = setInterval(function(){ show(cur+1); }, 5000); }
    window.bhsNext = function(){ show(cur+1); tick(); };
    window.bhsPrev = function(){ show(cur-1); tick(); };
    window.bhsGo   = function(n){ show(n); tick(); };
    tick();
  }

  /* ── SCROLL REVEAL ── */
  var revEls = document.querySelectorAll(".bhs-reveal");
  if ("IntersectionObserver" in window) {
    var obs = new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        if (e.isIntersecting) { e.target.classList.add("visible"); obs.unobserve(e.target); }
      });
    }, { threshold: 0.12 });
    revEls.forEach(function(el){ obs.observe(el); });
  } else {
    revEls.forEach(function(el){ el.classList.add("visible"); });
  }

  /* ── STATS COUNTER ── */
  function animateCounter(el, target) {
    var start = 0, duration = 1800, step = 16;
    var inc = Math.ceil(target / (duration / step));
    var t = setInterval(function(){
      start += inc;
      if (start >= target) { start = target; clearInterval(t); }
      var formatted = start >= 1000 ? (start/1000).toFixed(start >= 10000 ? 0 : 1) + "K+" : start + (target === 99 ? "%" : "+");
      el.textContent = formatted;
    }, step);
  }
  var statNums = document.querySelectorAll(".bhs-stat-num");
  var statObs = new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if (e.isIntersecting) {
        var target = parseInt(e.target.getAttribute("data-target"));
        animateCounter(e.target, target);
        statObs.unobserve(e.target);
      }
    });
  }, { threshold: 0.5 });
  statNums.forEach(function(el){ statObs.observe(el); });

}());
</script>

</div>
</div>
</t>
