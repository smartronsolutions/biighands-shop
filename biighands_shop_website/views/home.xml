<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

<template id="home" name="Biighands Home">
<t t-call="website.layout">
<t t-set="pageName" t-value="'home'"/>

<style>
/* ── RESET ── */
.bh *{box-sizing:border-box;margin:0;padding:0}
.bh a{text-decoration:none}

/* ── HERO CAROUSEL ── */
.bh-hero{position:relative;overflow:hidden;background:#0D2B2B}
.bh-slides{display:flex;transition:transform .6s cubic-bezier(.4,0,.2,1)}
.bh-slide{min-width:100%;position:relative;height:480px}
.bh-slide img{width:100%;height:100%;object-fit:cover;display:block;opacity:.85}
.bh-slide-caption{
    position:absolute;top:50%;left:8%;transform:translateY(-50%);
    color:#fff;max-width:520px
}
.bh-slide-caption span{
    display:inline-block;background:rgba(19,194,197,.25);
    border:1px solid rgba(19,194,197,.5);color:#A8ECED;
    font-size:11px;font-weight:700;letter-spacing:2px;
    text-transform:uppercase;padding:4px 14px;border-radius:100px;margin-bottom:14px
}
.bh-slide-caption h2{
    font-size:clamp(28px,4vw,52px);font-weight:900;
    line-height:1.1;letter-spacing:-1.5px;margin-bottom:14px
}
.bh-slide-caption p{font-size:15px;opacity:.8;margin-bottom:22px}
.bh-slide-caption a{
    display:inline-block;background:#13C2C5;color:#fff;
    font-weight:800;font-size:14px;padding:13px 30px;
    border-radius:8px;transition:background .2s
}
.bh-slide-caption a:hover{background:#037C7C}
.bh-arrow{
    position:absolute;top:50%;transform:translateY(-50%);
    background:rgba(255,255,255,.15);border:none;color:#fff;
    width:46px;height:46px;border-radius:50%;font-size:20px;
    cursor:pointer;transition:background .2s;z-index:10;
    display:flex;align-items:center;justify-content:center
}
.bh-arrow:hover{background:rgba(19,194,197,.7)}
.bh-arrow-prev{left:20px}
.bh-arrow-next{right:20px}
.bh-dots{position:absolute;bottom:18px;left:50%;transform:translateX(-50%);
    display:flex;gap:8px;z-index:10}
.bh-dot{width:8px;height:8px;border-radius:50%;background:rgba(255,255,255,.4);
    border:none;cursor:pointer;transition:all .2s}
.bh-dot.active{background:#13C2C5;width:24px;border-radius:4px}

/* ── USP STRIP ── */
.bh-usp{background:#13C2C5}
.bh-usp-inner{max-width:1200px;margin:0 auto;display:flex;align-items:stretch}
.bh-usp-item{
    flex:1;display:flex;align-items:center;gap:10px;
    padding:14px 20px;border-right:1px solid rgba(255,255,255,.25);
    color:#fff;font-size:13px;font-weight:600
}
.bh-usp-item:last-child{border-right:none}
.bh-usp-icon{font-size:22px;flex-shrink:0}

/* ── SECTIONS ── */
.bh-section{max-width:1200px;margin:0 auto;padding:60px 20px}
.bh-section-head{text-align:center;margin-bottom:40px}
.bh-section-head h2{font-size:28px;font-weight:900;color:#0D2B2B;letter-spacing:-1px;margin-bottom:8px}
.bh-section-head p{color:#64748B;font-size:15px}
.bh-tag{
    display:inline-block;background:rgba(19,194,197,.1);
    color:#037C7C;font-size:11px;font-weight:800;
    text-transform:uppercase;letter-spacing:2px;
    padding:4px 14px;border-radius:100px;margin-bottom:10px
}

/* ── CATEGORIES ── */
.bh-cats{background:#fff}
.bh-cat-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:16px}
.bh-cat-card{
    background:#F8FAFC;border:1.5px solid #E2E8F0;
    border-radius:14px;padding:22px 14px;text-align:center;transition:all .2s
}
.bh-cat-card:hover{border-color:#13C2C5;background:#E6FAFA;transform:translateY(-3px)}
.bh-cat-icon{font-size:32px;margin-bottom:10px}
.bh-cat-card h4{font-size:13px;font-weight:700;color:#0D2B2B}
.bh-cat-card span{font-size:11px;color:#94A3B8}

/* ── PRODUCTS ── */
.bh-products-bg{background:#F0F2F5}
.bh-prod-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:20px}
.bh-prod-card{
    background:#fff;border:1.5px solid #E2E8F0;
    border-radius:14px;overflow:hidden;
    transition:all .25s cubic-bezier(.25,.8,.25,1);display:block
}
.bh-prod-card:hover{
    border-color:#13C2C5;
    box-shadow:0 12px 36px rgba(19,194,197,.15);
    transform:translateY(-5px)
}
.bh-prod-img{
    background:linear-gradient(135deg,#F8FAFC,#EEF2F7);
    height:200px;display:flex;align-items:center;justify-content:center;overflow:hidden
}
.bh-prod-img img{max-width:100%;max-height:100%;object-fit:contain;transition:transform .35s}
.bh-prod-card:hover .bh-prod-img img{transform:scale(1.07)}
.bh-prod-body{padding:14px 16px 16px}
.bh-prod-name{
    font-size:13.5px;font-weight:700;color:#1A1A1A;line-height:1.4;margin-bottom:8px;
    display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden
}
.bh-prod-price{font-size:18px;font-weight:900;color:#13C2C5;margin-bottom:12px}
.bh-add-btn{
    display:block;width:100%;background:#0D2B2B;color:#fff;
    border:none;padding:11px 0;border-radius:8px;
    font-size:13px;font-weight:800;cursor:pointer;transition:background .2s;text-align:center
}
.bh-add-btn:hover{background:#13C2C5}
.bh-view-all{
    display:inline-block;background:#0D2B2B;color:#fff;
    font-weight:800;font-size:14px;padding:14px 40px;
    border-radius:8px;transition:background .2s
}
.bh-view-all:hover{background:#13C2C5;color:#fff}

/* ── PROMOS ── */
.bh-promos{background:#fff}
.bh-promo-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px}
.bh-promo{
    border-radius:16px;padding:40px 36px;
    overflow:hidden;min-height:200px;
    display:flex;flex-direction:column;justify-content:center
}
.bh-promo-1{background:linear-gradient(135deg,#0D2B2B,#13C2C5)}
.bh-promo-2{background:linear-gradient(135deg,#064444,#0D2B2B)}
.bh-promo h3{font-size:22px;font-weight:900;color:#fff;margin-bottom:8px}
.bh-promo p{color:rgba(255,255,255,.75);font-size:14px;margin-bottom:18px}
.bh-promo a{
    display:inline-block;background:#fff;color:#0D2B2B;
    font-weight:800;font-size:13px;padding:10px 22px;border-radius:8px;transition:all .2s
}
.bh-promo a:hover{background:#13C2C5;color:#fff}

/* ── NEWSLETTER ── */
.bh-newsletter{background:#0D2B2B}
.bh-nl-inner{max-width:600px;margin:0 auto;text-align:center;padding:60px 20px}
.bh-nl-inner h2{font-size:26px;font-weight:900;color:#fff;margin-bottom:8px}
.bh-nl-inner p{color:rgba(255,255,255,.65);margin-bottom:28px}
.bh-nl-form{display:flex;gap:10px}
.bh-nl-form input{
    flex:1;padding:13px 18px;border-radius:8px;
    border:none;font-size:14px;outline:none
}
.bh-nl-form button{
    background:#13C2C5;color:#fff;border:none;
    padding:13px 24px;border-radius:8px;font-weight:800;
    font-size:14px;cursor:pointer;white-space:nowrap;transition:background .2s
}
.bh-nl-form button:hover{background:#037C7C}

/* ── RESPONSIVE ── */
@media(max-width:768px){
    .bh-slide{height:300px}
    .bh-promo-grid{grid-template-columns:1fr}
    .bh-nl-form{flex-direction:column}
}
@media(max-width:480px){
    .bh-cat-grid{grid-template-columns:repeat(3,1fr)}
    .bh-prod-grid{grid-template-columns:repeat(2,1fr)}
    .bh-usp-inner{flex-wrap:wrap}
    .bh-usp-item{flex:0 0 50%}
}
</style>

<div class="bh">

<!-- ══ HERO ══ -->
<div class="bh-hero">
    <div class="bh-slides" id="bhSlides">
        <div class="bh-slide">
            <img src="/biighands_shop_website/static/images/banner1.png" alt=""/>
            <div class="bh-slide-caption">
                <span>New Arrivals</span>
                <h2>Professional Tools for Every Job</h2>
                <p>Trade-quality equipment at the best prices.</p>
                <a href="/shop">Shop Now</a>
            </div>
        </div>
        <div class="bh-slide">
            <img src="/biighands_shop_website/static/images/banner2.png" alt=""/>
            <div class="bh-slide-caption">
                <span>Best Sellers</span>
                <h2>Top Picks from Our Experts</h2>
                <p>Trusted by professionals across the industry.</p>
                <a href="/shop">Explore Range</a>
            </div>
        </div>
        <div class="bh-slide">
            <img src="/biighands_shop_website/static/images/banner3.png" alt=""/>
            <div class="bh-slide-caption">
                <span>Special Offer</span>
                <h2>Save Big on Bulk Orders</h2>
                <p>Contact us for trade account pricing today.</p>
                <a href="/contactus">Get Quote</a>
            </div>
        </div>
    </div>
    <button class="bh-arrow bh-arrow-prev" id="bhPrev">&#8592;</button>
    <button class="bh-arrow bh-arrow-next" id="bhNext">&#8594;</button>
    <div class="bh-dots" id="bhDots">
        <button class="bh-dot active"></button>
        <button class="bh-dot"></button>
        <button class="bh-dot"></button>
    </div>
</div>

<!-- ══ USP ══ -->
<div class="bh-usp">
    <div class="bh-usp-inner">
        <div class="bh-usp-item"><span class="bh-usp-icon">🚚</span>Free Delivery over $50</div>
        <div class="bh-usp-item"><span class="bh-usp-icon">⚡</span>Same-Day Dispatch</div>
        <div class="bh-usp-item"><span class="bh-usp-icon">📦</span>Click &amp; Collect</div>
        <div class="bh-usp-item"><span class="bh-usp-icon">🔄</span>30-Day Returns</div>
    </div>
</div>

<!-- ══ CATEGORIES ══ -->
<div class="bh-cats">
    <div class="bh-section">
        <div class="bh-section-head">
            <div class="bh-tag">Browse by Category</div>
            <h2>Shop by Department</h2>
            <p>Find exactly what you need, fast.</p>
        </div>
        <div class="bh-cat-grid">
            <a href="/shop" class="bh-cat-card"><div class="bh-cat-icon">🔧</div><h4>Tools</h4><span>Hand &amp; Power</span></a>
            <a href="/shop" class="bh-cat-card"><div class="bh-cat-icon">💡</div><h4>Electrical</h4><span>Cables &amp; Fittings</span></a>
            <a href="/shop" class="bh-cat-card"><div class="bh-cat-icon">🔩</div><h4>Fixings</h4><span>Screws &amp; Bolts</span></a>
            <a href="/shop" class="bh-cat-card"><div class="bh-cat-icon">🪣</div><h4>Cleaning</h4><span>Products &amp; Equipment</span></a>
            <a href="/shop" class="bh-cat-card"><div class="bh-cat-icon">🏗️</div><h4>Building</h4><span>Materials</span></a>
            <a href="/shop" class="bh-cat-card"><div class="bh-cat-icon">🔐</div><h4>Security</h4><span>Locks &amp; Access</span></a>
            <a href="/shop" class="bh-cat-card"><div class="bh-cat-icon">🎨</div><h4>Painting</h4><span>Paints &amp; Brushes</span></a>
            <a href="/shop" class="bh-cat-card"><div class="bh-cat-icon">➕</div><h4>All Products</h4><span>View everything</span></a>
        </div>
    </div>
</div>

<!-- ══ FEATURED PRODUCTS ══ -->
<div class="bh-products-bg">
    <div class="bh-section">
        <div class="bh-section-head">
            <div class="bh-tag">Top Picks</div>
            <h2>Featured Products</h2>
            <p>Best-selling items chosen by our team.</p>
        </div>
        <div class="bh-prod-grid">
            <t t-foreach="featured_products" t-as="product">
                <a t-att-href="product.website_url" class="bh-prod-card">
                    <div class="bh-prod-img">
                        <img t-att-src="'/web/image/product.template/%d/image_512' % product.id"
                             t-att-alt="product.name" loading="lazy"/>
                    </div>
                    <div class="bh-prod-body">
                        <div class="bh-prod-name" t-esc="product.name"/>
                        <div class="bh-prod-price">
                            <t t-esc="product.currency_id.symbol"/><t t-esc="'%.2f' % product.list_price"/>
                        </div>
                        <form action="/shop/cart/update" method="post" onclick="event.stopPropagation()">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <input type="hidden" name="product_id" t-att-value="product.product_variant_id.id"/>
                            <input type="hidden" name="add_qty" value="1"/>
                            <button type="submit" class="bh-add-btn">Add to Cart</button>
                        </form>
                    </div>
                </a>
            </t>
        </div>
        <div style="text-align:center;margin-top:36px">
            <a href="/shop" class="bh-view-all">View All Products</a>
        </div>
    </div>
</div>

<!-- ══ PROMO BANNERS ══ -->
<div class="bh-promos">
    <div class="bh-section">
        <div class="bh-promo-grid">
            <div class="bh-promo bh-promo-1">
                <h3>Trade Accounts Available</h3>
                <p>Get exclusive pricing and dedicated support for your business.</p>
                <a href="/contactus">Apply Today</a>
            </div>
            <div class="bh-promo bh-promo-2">
                <h3>Bulk Order Discounts</h3>
                <p>Save more when you order more. Perfect for contractors.</p>
                <a href="/shop">Shop Now</a>
            </div>
        </div>
    </div>
</div>

<!-- ══ NEWSLETTER ══ -->
<div class="bh-newsletter">
    <div class="bh-nl-inner">
        <h2>Stay in the Loop</h2>
        <p>Get the latest deals, new arrivals and trade tips straight to your inbox.</p>
        <form class="bh-nl-form" action="#" method="post">
            <input type="email" placeholder="Your email address" required="required"/>
            <button type="submit">Subscribe</button>
        </form>
    </div>
</div>

</div>

<script>
(function(){
    var slides = document.getElementById('bhSlides');
    var dots   = document.querySelectorAll('#bhDots .bh-dot');
    var total  = 3;
    var cur    = 0;
    var timer;

    function go(n){
        cur = (n + total) % total;
        slides.style.transform = 'translateX(-' + (cur * 100) + '%)';
        dots.forEach(function(d,i){ d.classList.toggle('active', i === cur); });
    }
    function startAuto(){ timer = setInterval(function(){ go(cur + 1); }, 4500); }
    function stopAuto(){  clearInterval(timer); }

    document.getElementById('bhNext').onclick = function(){ stopAuto(); go(cur+1); startAuto(); };
    document.getElementById('bhPrev').onclick = function(){ stopAuto(); go(cur-1); startAuto(); };
    dots.forEach(function(d, i){ d.onclick = function(){ stopAuto(); go(i); startAuto(); }; });

    startAuto();
})();
</script>

</t>
</template>

<record id="website_page_home" model="website.page">
    <field name="view_id" ref="home"/>
    <field name="url">/home</field>
    <field name="name">Biighands Home</field>
    <field name="website_published">True</field>
    <field name="is_published">True</field>
</record>

</data>
</odoo>
