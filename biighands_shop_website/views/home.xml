<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

<template id="home" name="Biighands Shop Home">
<t t-call="website.layout">
<t t-set="additional_title">Biighands Shop | Professional Tools and Hardware</t>
<div id="wrap">
<div class="bhs-page">

<style>
/* ============================================================
   BIIGHANDS HOME — Full Premium Design
   ============================================================ */

.bhs-page *, .bhs-page *::before, .bhs-page *::after {
  box-sizing: border-box; margin: 0; padding: 0;
}
.bhs-page {
  font-family: 'Inter', 'Segoe UI', Arial, sans-serif;
  color: #1A1A1A; background: #fff;
}

/* ---------- HERO SLIDER ---------- */
.bhs-hero { position: relative; overflow: hidden; background: #080E0E; user-select: none; }
.bhs-slide { position: relative; min-height: 520px; display: none; align-items: center; }
.bhs-slide.go { display: flex; animation: bhsIn .6s ease; }
@keyframes bhsIn { from { opacity: 0; transform: scale(1.03); } to { opacity: 1; transform: scale(1); } }
.bhs-slide-bg {
  position: absolute; inset: 0;
  background-size: cover; background-position: center right;
  transition: transform 6s ease;
}
.bhs-slide.go .bhs-slide-bg { transform: scale(1.05); }
.bhs-slide-1 .bhs-slide-bg { background-position: center right; }
.bhs-slide-2 .bhs-slide-bg { background-position: center right; }
.bhs-slide-3 .bhs-slide-bg { background-position: center right; }
.bhs-slide-dim {
  position: absolute; inset: 0;
  background: linear-gradient(105deg,
    rgba(5,15,20,.95) 0%, rgba(13,27,42,.65) 50%, rgba(13,27,42,.1) 100%);
  z-index: 1;
}
.bhs-slide-body {
  position: relative; z-index: 2;
  max-width: 1280px; margin: 0 auto; width: 100%; padding: 90px 72px 110px;
}
.bhs-slide-body .bhs-tag { margin-bottom: 20px; }
.bhs-slide-body h1 {
  font-size: clamp(34px, 4.4vw, 56px); font-weight: 900; color: #fff;
  line-height: 1.05; letter-spacing: 0; max-width: 560px; margin: 0 0 18px;
}
.bhs-slide-body h1 em { font-style: normal; color: #13C2C5; }
.bhs-slide-body p {
  font-size: 17px; color: rgba(255,255,255,.75);
  max-width: 455px; line-height: 1.7; margin: 0 0 34px;
}
.bhs-btns { display: flex; gap: 14px; flex-wrap: wrap; align-items: center; }
.bhs-btn {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 15px 34px; border-radius: 8px;
  font-size: 15px; font-weight: 800; text-decoration: none;
  transition: all .2s;
}
.bhs-btn.solid { background: #13C2C5; color: #fff; }
.bhs-btn.solid:hover { background: #037C7C; color: #fff; transform: translateY(-2px); box-shadow: 0 8px 24px rgba(19,194,197,.4); }
.bhs-btn.ghost { background: rgba(255,255,255,.1); color: #fff; border: 1.5px solid rgba(255,255,255,.42); }
.bhs-btn.ghost:hover { background: #fff; color: #1A1A1A; }
.bhs-tag {
  display: inline-block; background: #13C2C5; color: #fff;
  font-size: 11px; font-weight: 800; text-transform: uppercase;
  letter-spacing: 1.5px; padding: 5px 14px; border-radius: 4px;
}
.bhs-arrow {
  position: absolute; top: 50%; transform: translateY(-50%); z-index: 20;
  width: 52px; height: 52px; border-radius: 50%;
  background: rgba(0,0,0,.35); border: 1.5px solid rgba(255,255,255,.2);
  color: #fff; font-size: 20px; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  transition: all .2s; backdrop-filter: blur(4px);
}
.bhs-arrow:hover { background: #13C2C5; border-color: #13C2C5; transform: translateY(-50%) scale(1.08); }
.bhs-prev { left: 24px; } .bhs-next { right: 24px; }
.bhs-dots { position: absolute; bottom: 24px; left: 50%; transform: translateX(-50%); display: flex; gap: 8px; z-index: 20; }
.bhs-dot { width: 8px; height: 8px; border-radius: 50%; background: rgba(255,255,255,.4); border: none; cursor: pointer; padding: 0; transition: all .3s; }
.bhs-dot.on { background: #13C2C5; width: 28px; border-radius: 4px; }
.bhs-hero::after {
  content: ''; position: absolute; left: 0; right: 0; bottom: 0; height: 96px;
  background: linear-gradient(180deg, transparent 0%, rgba(255,255,255,.96) 100%);
  z-index: 3; pointer-events: none;
}
.bhs-slide-body > * { position: relative; z-index: 2; }
.bhs-slide-body::before {
  content: ''; position: absolute; left: 48px; top: 64px; width: min(560px, 48vw); height: 370px;
  background: linear-gradient(135deg, rgba(8,18,20,.78), rgba(8,18,20,.46));
  border: 1px solid rgba(255,255,255,.18); border-radius: 18px;
  box-shadow: 0 26px 80px rgba(0,0,0,.34);
  backdrop-filter: blur(5px); z-index: 1;
}

/* ---------- USP BAR ---------- */
.bhs-usp { background: #fff; position: relative; z-index: 5; }
.bhs-usp-g { max-width: 1280px; margin: 0 auto; display: grid; grid-template-columns: repeat(4,1fr); }
.bhs-usp-i { display: flex; align-items: center; gap: 13px; padding: 18px 28px; border-right: 1px solid #E8EDF2; }
.bhs-usp-i:last-child { border-right: none; }
.bhs-usp-ic {
  width: 42px; height: 42px; border-radius: 12px; line-height: 42px; text-align: center;
  font-size: 22px; flex-shrink: 0; background: #E9F9F8; color: #037C7C;
}
.bhs-usp-t strong { display: block; color: #0D2B2B; font-size: 14px; font-weight: 800; }
.bhs-usp-t small { color: #6B7280; font-size: 12px; }

/* ---------- STATS COUNTER ---------- */
.bhs-stats { background: #0D2B2B; padding: 50px 24px; }
.bhs-stats-g {
  max-width: 1100px; margin: 0 auto;
  display: grid; grid-template-columns: repeat(4,1fr); gap: 0;
}
.bhs-stat {
  text-align: center; padding: 20px 24px;
  border-right: 1px solid rgba(255,255,255,.1);
  position: relative;
}
.bhs-stat:last-child { border-right: none; }
.bhs-stat-num {
  font-size: 48px; font-weight: 900; color: #13C2C5;
  line-height: 1; letter-spacing: 0; margin-bottom: 8px;
  display: block;
}
.bhs-stat-lbl { font-size: 14px; color: rgba(255,255,255,.65); font-weight: 600; }
.bhs-stat-icon { font-size: 28px; margin-bottom: 12px; display: block; }

/* ---------- SHARED UTILS ---------- */
.bhs-w { max-width: 1280px; margin: 0 auto; padding: 0 24px; }
.bhs-hd { display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 32px; }
.bhs-hd-left h2 { font-size: 28px; font-weight: 900; color: #0D2B2B; letter-spacing: 0; }
.bhs-hd-left h2 em { font-style: normal; color: #13C2C5; }
.bhs-hd-left p { font-size: 14px; color: #6B7280; margin-top: 4px; }
.bhs-all { color: #13C2C5; font-weight: 700; font-size: 14px; text-decoration: none; white-space: nowrap; border: 1.5px solid #13C2C5; padding: 8px 18px; border-radius: 6px; transition: all .2s; }
.bhs-all:hover { background: #13C2C5; color: #fff; }

/* ---------- CATEGORIES ---------- */
.bhs-cat-s { padding: 70px 0 50px; }
.bhs-cat-g { display: grid; grid-template-columns: repeat(6,1fr); gap: 14px; }
.bhs-cat {
  background: linear-gradient(180deg, #fff 0%, #F8FAFC 100%); border: 1.5px solid #E8EDF2;
  border-radius: 8px; padding: 24px 12px 20px;
  text-align: center; text-decoration: none; color: #1A1A1A;
  transition: all .25s; display: flex; flex-direction: column; align-items: center; gap: 10px;
}
.bhs-cat:hover {
  border-color: #13C2C5; background: #fff;
  transform: translateY(-4px);
  box-shadow: 0 16px 34px rgba(13,43,43,.12); color: #0D2B2B;
}
.bhs-cat-ic {
  width: 68px; height: 68px; border-radius: 8px;
  background: #fff; border: 1.5px solid #E8EDF2;
  display: flex; align-items: center; justify-content: center;
  font-size: 30px; transition: all .25s;
}
.bhs-cat:hover .bhs-cat-ic { border-color: #13C2C5; background: rgba(19,194,197,.06); }
.bhs-cat-nm { font-size: 13px; font-weight: 700; line-height: 1.35; }
.bhs-cat-ct { font-size: 11px; color: #9CA3AF; }

/* ---------- WHY CHOOSE US ---------- */
.bhs-why { background: linear-gradient(135deg, #F6FBFA 0%, #F8FAFC 52%, #FFF7ED 100%); padding: 80px 0; }
.bhs-why-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 28px; }
.bhs-why-card {
  background: #fff; border-radius: 8px; padding: 34px 28px;
  border: 1.5px solid #E8EDF2;
  transition: all .25s; position: relative; overflow: hidden;
}
.bhs-why-card::before {
  content: ''; position: absolute; top: 0; left: 0;
  width: 4px; height: 100%;
  background: linear-gradient(to bottom, #13C2C5, #037C7C);
  border-radius: 4px 0 0 4px;
}
.bhs-why-card:hover { transform: translateY(-5px); box-shadow: 0 16px 40px rgba(0,0,0,.09); border-color: #13C2C5; }
.bhs-why-ic { font-size: 42px; margin-bottom: 18px; display: block; }
.bhs-why-card h3 { font-size: 18px; font-weight: 800; color: #0D2B2B; margin-bottom: 10px; }
.bhs-why-card p { font-size: 14px; color: #4B5563; line-height: 1.7; }

/* ---------- DEALS + PRODUCTS ---------- */
.bhs-deals-s { padding: 70px 0; background: #F4F6F9; }
.bhs-deals-l { display: grid; grid-template-columns: 280px 1fr; gap: 24px; }
.bhs-deal-card {
  background: linear-gradient(155deg, #0D2B2B 0%, #080E0E 100%);
  border-radius: 8px; padding: 38px 28px;
  display: flex; flex-direction: column; min-height: 460px;
  position: relative; overflow: hidden;
}
.bhs-deal-card::after {
  content: ''; position: absolute; bottom: -60px; right: -60px;
  width: 220px; height: 220px; border-radius: 50%;
  background: rgba(19,194,197,.15);
}
.bhs-deal-card::before {
  content: ''; position: absolute; top: -40px; right: -20px;
  width: 140px; height: 140px; border-radius: 50%;
  background: rgba(19,194,197,.07);
}
.bhs-deal-top { flex: 1; position: relative; z-index: 1; }
.bhs-d-badge {
  display: inline-block; background: #13C2C5; color: #fff;
  font-size: 10px; font-weight: 900; text-transform: uppercase; letter-spacing: 1.5px;
  padding: 5px 12px; border-radius: 4px; margin-bottom: 24px;
}
.bhs-deal-card h3 { font-size: 30px; font-weight: 900; color: #fff; line-height: 1.1; margin-bottom: 14px; }
.bhs-deal-card p { font-size: 14px; color: rgba(255,255,255,.62); line-height: 1.75; }
.bhs-d-cta {
  display: inline-block; background: #13C2C5; color: #fff;
  padding: 14px 28px; border-radius: 8px; font-size: 14px; font-weight: 800;
  text-decoration: none; margin-top: 30px; position: relative; z-index: 1;
  transition: all .2s;
}
.bhs-d-cta:hover { background: #037C7C; color: #fff; transform: translateY(-2px); }

/* Product cards */
.bhs-prod-g { display: grid; grid-template-columns: repeat(4,1fr); gap: 16px; }
.bhs-prod {
  background: #fff; border: 1.5px solid #E8EDF2; border-radius: 8px;
  overflow: hidden; display: flex; flex-direction: column; transition: all .25s;
  position: relative;
}
.bhs-prod:hover { border-color: #13C2C5; box-shadow: 0 10px 30px rgba(19,194,197,.14); transform: translateY(-4px); }
.bhs-prod-link { text-decoration: none; color: #1A1A1A; display: flex; flex-direction: column; flex: 1; }
.bhs-prod-link:hover { color: #1A1A1A; }
.bhs-prod-img {
  height: 185px; background: #F8FAFC;
  display: flex; align-items: center; justify-content: center;
  position: relative; overflow: hidden;
}
.bhs-prod-img img { width: 100%; height: 100%; object-fit: contain; padding: 14px; transition: transform .35s; }
.bhs-prod:hover .bhs-prod-img img { transform: scale(1.08); }
.bhs-sticker {
  position: absolute; top: 10px; left: 10px;
  background: #13C2C5; color: #fff; font-size: 10px; font-weight: 800;
  padding: 3px 8px; border-radius: 4px; text-transform: uppercase;
}
.bhs-sticker.nw { background: #0D2B2B; }
.bhs-prod-b { padding: 14px 16px 10px; display: flex; flex-direction: column; flex: 1; }
.bhs-prod-cat { font-size: 10.5px; color: #9CA3AF; font-weight: 700; text-transform: uppercase; letter-spacing: .5px; margin-bottom: 5px; }
.bhs-prod-nm { font-size: 13.5px; font-weight: 700; line-height: 1.4; margin-bottom: 8px; flex: 1;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
/* Star rating */
.bhs-stars { color: #F59E0B; font-size: 12px; letter-spacing: 1px; margin-bottom: 8px; }
.bhs-stars span { color: #9CA3AF; font-size: 11px; margin-left: 4px; font-weight: 600; }
.bhs-pricing { display: flex; align-items: baseline; gap: 8px; margin-bottom: 2px; }
.bhs-price { font-size: 22px; font-weight: 900; color: #13C2C5; }
.bhs-was { font-size: 13px; color: #9CA3AF; text-decoration: line-through; }
.bhs-atc-form { padding: 12px 14px 14px; }
.bhs-atc {
  display: block; width: 100%; text-align: center;
  background: #0D2B2B; color: #fff; padding: 11px 0;
  font-size: 13px; font-weight: 800; border-radius: 8px; border: none;
  cursor: pointer; transition: all .2s; letter-spacing: .3px;
}
.bhs-atc:hover { background: #13C2C5; color: #fff; }

/* ---------- PROMO BANNERS ---------- */
.bhs-promo-s { padding: 70px 0; }
.bhs-promo-r { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
.bhs-promo {
  border-radius: 8px; height: 300px; position: relative; overflow: hidden;
  display: flex; align-items: center; text-decoration: none; background: #0D2B2B;
}
.bhs-promo::before {
  content: ''; position: absolute; inset: 0;
  background: linear-gradient(90deg, rgba(5,15,20,.92) 0%, rgba(13,27,42,.25) 100%);
  z-index: 1;
}
.bhs-promo img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
.bhs-promo-b { position: relative; z-index: 2; padding: 48px; }
.bhs-promo-b h3 { font-size: 28px; font-weight: 900; color: #fff; line-height: 1.1; margin-bottom: 10px; }
.bhs-promo-b p { font-size: 14px; color: rgba(255,255,255,.75); margin-bottom: 22px; line-height: 1.6; }
.bhs-promo-lnk {
  display: inline-block; background: #13C2C5; color: #fff;
  padding: 12px 26px; border-radius: 8px; font-size: 13px; font-weight: 800;
  text-decoration: none; transition: all .2s;
}
.bhs-promo-lnk:hover { background: #037C7C; color: #fff; }

/* ---------- REVIEWS ---------- */
.bhs-reviews { background: #F4F6F9; padding: 80px 0; }
.bhs-rev-g { display: grid; grid-template-columns: repeat(3,1fr); gap: 22px; }
.bhs-rev-card {
  background: #fff; border-radius: 8px; padding: 28px 26px;
  border: 1.5px solid #E8EDF2; transition: all .25s;
  position: relative;
}
.bhs-rev-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,.08); border-color: #13C2C5; }
.bhs-rev-card::before {
  content: '\201C'; position: absolute; top: 18px; right: 22px;
  font-size: 60px; color: rgba(19,194,197,.15); line-height: 1;
  font-family: Georgia, serif; font-weight: 900;
}
.bhs-rev-stars { color: #F59E0B; font-size: 14px; letter-spacing: 2px; margin-bottom: 14px; }
.bhs-rev-text { font-size: 14px; color: #374151; line-height: 1.75; margin-bottom: 20px; font-style: italic; }
.bhs-rev-author { display: flex; align-items: center; gap: 12px; }
.bhs-rev-av {
  width: 42px; height: 42px; border-radius: 50%;
  background: linear-gradient(135deg, #13C2C5, #037C7C);
  display: flex; align-items: center; justify-content: center;
  color: #fff; font-size: 16px; font-weight: 800; flex-shrink: 0;
}
.bhs-rev-info strong { display: block; font-size: 14px; font-weight: 800; color: #0D2B2B; }
.bhs-rev-info small { font-size: 12px; color: #9CA3AF; }
.bhs-rev-badge {
  display: inline-block; background: rgba(19,194,197,.1); color: #037C7C;
  font-size: 10px; font-weight: 800; padding: 2px 8px; border-radius: 4px;
  margin-top: 3px;
}

/* ---------- BRANDS ---------- */
.bhs-brands-s { background: #fff; border-top: 1px solid #E8EDF2; border-bottom: 1px solid #E8EDF2; padding: 48px 0; }
.bhs-brands-lbl { font-size: 12px; font-weight: 700; color: #9CA3AF; text-transform: uppercase; letter-spacing: 1.5px; text-align: center; margin-bottom: 28px; }
.bhs-brands-g { display: grid; grid-template-columns: repeat(6,1fr); gap: 14px; }
.bhs-brand {
  background: #F8FAFC; border: 1.5px solid #E8EDF2; border-radius: 10px; height: 72px;
  display: flex; align-items: center; justify-content: center;
  font-size: 14px; font-weight: 800; color: #6B7280; transition: all .2s;
}
.bhs-brand:hover { border-color: #13C2C5; color: #0D2B2B; background: #fff; box-shadow: 0 4px 14px rgba(19,194,197,.1); }

/* ---------- INFO BAND ---------- */
.bhs-info { background: linear-gradient(105deg, #080E0E 0%, #0D2B2B 100%); padding: 70px 24px; }
.bhs-info-g { max-width: 1280px; margin: 0 auto; display: grid; grid-template-columns: repeat(3,1fr); gap: 48px; }
.bhs-info-c { text-align: center; }
.bhs-info-ic {
  width: 72px; height: 72px; border-radius: 18px;
  background: rgba(19,194,197,.12); border: 1.5px solid rgba(19,194,197,.25);
  display: flex; align-items: center; justify-content: center;
  font-size: 32px; margin: 0 auto 20px;
}
.bhs-info-c h3 { font-size: 18px; font-weight: 800; color: #fff; margin-bottom: 10px; }
.bhs-info-c p { font-size: 14px; color: rgba(255,255,255,.6); line-height: 1.75; }
.bhs-info-c a { color: #AEEBEC; font-weight: 700; text-decoration: none; }
.bhs-info-c a:hover { color: #13C2C5; }

/* ---------- NEWSLETTER ---------- */
.bhs-news-s {
  padding: 80px 24px;
  background: linear-gradient(135deg, #0D2B2B 0%, #064444 100%);
  position: relative; overflow: hidden;
}
.bhs-news-s::before {
  content: ''; position: absolute; top: -80px; right: -80px;
  width: 400px; height: 400px; border-radius: 50%;
  background: rgba(19,194,197,.08); pointer-events: none;
}
.bhs-news-s::after {
  content: ''; position: absolute; bottom: -100px; left: -60px;
  width: 300px; height: 300px; border-radius: 50%;
  background: rgba(19,194,197,.06); pointer-events: none;
}
.bhs-news-w { max-width: 580px; margin: 0 auto; text-align: center; position: relative; z-index: 1; }
.bhs-news-w .bhs-tag { background: rgba(19,194,197,.2); color: #AEEBEC; margin-bottom: 18px; }
.bhs-news-w h2 { font-size: 32px; font-weight: 900; color: #fff; margin-bottom: 12px; letter-spacing: 0; }
.bhs-news-w p { font-size: 15px; color: rgba(255,255,255,.65); margin-bottom: 32px; line-height: 1.65; }
.bhs-news-f { display: flex; gap: 10px; background: rgba(255,255,255,.08); padding: 8px; border-radius: 12px; border: 1px solid rgba(255,255,255,.15); }
.bhs-news-f input {
  flex: 1; padding: 13px 18px; background: transparent;
  border: none; font-size: 14px; outline: none; color: #fff;
}
.bhs-news-f input::placeholder { color: rgba(255,255,255,.45); }
.bhs-news-f button {
  background: #13C2C5; color: #fff; border: none;
  padding: 13px 28px; border-radius: 8px; font-size: 14px; font-weight: 800;
  cursor: pointer; white-space: nowrap; transition: all .2s;
}
.bhs-news-f button:hover { background: #037C7C; transform: translateY(-1px); }
.bhs-news-trust { display: flex; gap: 20px; justify-content: center; margin-top: 18px; }
.bhs-news-trust span { font-size: 12px; color: rgba(255,255,255,.5); display: flex; align-items: center; gap: 5px; }

/* ---------- SCROLL REVEAL ---------- */
.bhs-reveal { opacity: 0; transform: translateY(28px); transition: opacity .6s ease, transform .6s ease; }
.bhs-reveal.visible { opacity: 1; transform: translateY(0); }
.bhs-reveal-d1 { transition-delay: .1s; }
.bhs-reveal-d2 { transition-delay: .2s; }
.bhs-reveal-d3 { transition-delay: .3s; }
.bhs-reveal-d4 { transition-delay: .4s; }
.bhs-reveal-d5 { transition-delay: .5s; }
.bhs-reveal-d6 { transition-delay: .6s; }

/* ---------- RESPONSIVE ---------- */
@media (max-width: 1100px) {
  .bhs-slide-body { padding-left: 48px; padding-right: 48px; }
  .bhs-slide-body::before { left: 28px; width: min(540px, 58vw); }
  .bhs-slide-body h1 { font-size: clamp(34px, 5vw, 50px); max-width: 500px; }
  .bhs-cat-g { grid-template-columns: repeat(4,1fr); }
  .bhs-deals-l { grid-template-columns: 1fr; }
  .bhs-deal-card { min-height: auto; }
  .bhs-prod-g { grid-template-columns: repeat(3,1fr); }
  .bhs-brands-g { grid-template-columns: repeat(4,1fr); }
  .bhs-usp-g { grid-template-columns: repeat(2,1fr); }
  .bhs-info-g { grid-template-columns: 1fr; gap: 36px; }
  .bhs-why-grid { grid-template-columns: 1fr; }
  .bhs-stats-g { grid-template-columns: repeat(2,1fr); }
  .bhs-rev-g { grid-template-columns: repeat(2,1fr); }
}
@media (max-width: 768px) {
  .bhs-hero { background: #081111; }
