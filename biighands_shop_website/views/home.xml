<!-- ══════════════════════════════════════════════
     CAROUSEL SCRIPT
════════════════════════════════════════════════ -->
<script type="text/javascript">
(function () {
  "use strict";
  var hero = document.getElementById("bhsHero");
  if (!hero) { return; }
  var slides = hero.querySelectorAll(".bhs-slide");
  var dots   = hero.querySelectorAll(".bhs-dot");
  var cur    = 0;
  var tmr;

  function show(n) {
    slides[cur].classList.remove("go");
    dots[cur].classList.remove("on");
    cur = ((n % slides.length) + slides.length) % slides.length;
    slides[cur].classList.add("go");
    dots[cur].classList.add("on");
  }

  function tick() {
    clearInterval(tmr);
    tmr = setInterval(function () { show(cur + 1); }, 5000);
  }

  window.bhsNext = function () { show(cur + 1); tick(); };
  window.bhsPrev = function () { show(cur - 1); tick(); };
  window.bhsGo   = function (n) { show(n);      tick(); };

  tick();
}());
</script>

