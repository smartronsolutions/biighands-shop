<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

<record id="bhs_auth_css" model="ir.ui.view">
  <field name="name">biighands_shop.auth_css</field>
  <field name="key">biighands_shop_website.auth_css</field>
  <field name="inherit_id" ref="website.layout"/>
  <field name="type">qweb</field>
  <field name="arch" type="xml">
    <xpath expr="//head" position="inside">
<style>
/* ============================================================
   BIIGHANDS — Auth Pages  (login / signup / reset)
   Fresh + Clean look, teal brand accents
   ============================================================ */

/* ── 1. HIDE ODOO DEFAULT NAVBAR ── */
html:has(.oe_website_login_container) .o_main_navbar,
html:has(.oe_website_login_container) .o_website_header { display: none !important; }

/* ── 2. PUSH BELOW OUR 152px FIXED HEADER ── */
html:has(.oe_website_login_container) #wrapwrap > main { padding-top: 152px !important; }

/* ── 3. FRESH LIGHT BACKGROUND ── */
html:has(.oe_website_login_container) body,
html:has(.oe_website_login_container) body.bg-100 {
  background: #EDF7F7 !important;
}

/* ── 4. AUTH CONTAINER ── */
#wrapwrap .oe_website_login_container {
  min-height: calc(100vh - 152px);
  padding: 48px 20px 60px !important;
  background: linear-gradient(160deg, #E4F5F5 0%, #EDF9F8 45%, #F7FFFE 100%) !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  position: relative !important;
  overflow: hidden !important;
  font-family: 'Inter', 'Segoe UI', Arial, sans-serif;
}

/* Soft pastel blobs */
#wrapwrap .oe_website_login_container::before {
  content: '';
  position: fixed;
  top: 10%; left: -10%;
  width: 50vw; height: 50vw; border-radius: 50%;
  background: radial-gradient(circle, rgba(19,194,197,.09) 0%, transparent 65%);
  pointer-events: none; z-index: 0;
}
#wrapwrap .oe_website_login_container::after {
  content: '';
  position: fixed;
  bottom: 5%; right: -10%;
  width: 40vw; height: 40vw; border-radius: 50%;
  background: radial-gradient(circle, rgba(3,150,150,.07) 0%, transparent 65%);
  pointer-events: none; z-index: 0;
}

/* ── 5. NARROW CENTERED COLUMN ── */
#wrapwrap .oe_website_login_container > .container {
  max-width: 480px !important;
  width: 100% !important;
  padding: 0 !important;
  margin: 0 auto !important;
  position: relative; z-index: 1;
}

#wrapwrap .oe_website_login_container .row { margin: 0 !important; }
#wrapwrap .oe_website_login_container .col,
#wrapwrap .oe_website_login_container [class*="col-"] {
  padding: 0 !important;
  max-width: 100% !important; flex: 0 0 100% !important;
}

/* ── 6. WHITE CARD ── */
#wrapwrap .oe_website_login_container .o_database_list,
#wrapwrap .oe_website_login_container .card.o_database_list {
  background: #FFFFFF !important;
  border: 1.5px solid rgba(19,194,197,.18) !important;
  border-radius: 20px !important;
  box-shadow:
    0 4px 6px rgba(0,0,0,.03),
    0 20px 60px rgba(19,194,197,.1),
    0 2px 0 #13C2C5 inset !important;
  overflow: hidden !important;
  max-width: none !important;
  width: 100% !important;
  margin: 0 !important;
}

#wrapwrap .oe_website_login_container .card-body {
  padding: 36px 36px 32px !important;
  background: transparent !important;
}

/* ── 7. LOGO AREA ── */
#wrapwrap .oe_website_login_container .card-body > .text-center.pb-3 {
  text-align: center !important;
  margin-bottom: 24px !important;
  padding-bottom: 18px !important;
  border-bottom: 1.5px solid #E8F6F6 !important;
}
#wrapwrap .oe_website_login_container .card-body > .text-center.pb-3 img {
  max-height: 40px !important;
  filter: none !important;
}

/* ── 8. PAGE TITLES & SUBTITLES ──
   Each form gets its own heading + tagline injected via ::before / ::after.
   ::before = big heading
   ::after  = supporting line below heading
   ──────────────────────────────────── */

/* Shared heading style */
#wrapwrap .oe_website_login_container .oe_login_form::before,
#wrapwrap .oe_website_login_container .oe_signup_form::before,
#wrapwrap .oe_website_login_container .oe_reset_password_form::before {
  display: block;
  font-size: 24px; font-weight: 800;
  letter-spacing: -0.5px; line-height: 1.2;
  color: #0C2B2B;
  margin-bottom: 5px;
}

/* ✏️ SIGN IN heading */
#wrapwrap .oe_website_login_container .oe_login_form::before {
  content: "Welcome back!";
}

/* ✏️ SIGN UP heading */
#wrapwrap .oe_website_login_container .oe_signup_form::before {
  content: "Join Biighands";
}

/* ✏️ FORGOT PASSWORD heading */
#wrapwrap .oe_website_login_container .oe_reset_password_form::before {
  content: "Forgot your password?";
}

/* Shared subtitle style */
#wrapwrap .oe_website_login_container .oe_login_form::after,
#wrapwrap .oe_website_login_container .oe_signup_form::after,
#wrapwrap .oe_website_login_container .oe_reset_password_form::after {
  display: block;
  font-size: 14px; font-weight: 400;
  color: #5E8080;
  line-height: 1.6; margin-bottom: 22px;
}

/* ✏️ SIGN IN — what does the user gain by signing in? */
#wrapwrap .oe_website_login_container .oe_login_form::after {
  content: "Sign in to your Biighands trade account to continue.";
}

/* ✏️ SIGN UP — why should they create an account? */
#wrapwrap .oe_website_login_container .oe_signup_form::after {
  content: "Create a free account and unlock exclusive trade pricing.";
}

/* ✏️ FORGOT PASSWORD — reassure them it's easy */
#wrapwrap .oe_website_login_container .oe_reset_password_form::after {
  content: "No worries! Enter your email and we'll send a reset link.";
}

/* ── 9. LABELS ── */
#wrapwrap .oe_website_login_container label {
  color: #2A4A4A !important;
  font-size: 13px !important; font-weight: 700 !important;
  margin-bottom: 6px !important;
}

/* ── 10. INPUTS ── */
#wrapwrap .oe_website_login_container .form-control {
  min-height: 48px !important;
  background: #F5FAFA !important;
  border: 1.5px solid #D4EDED !important;
  border-radius: 11px !important;
  padding: 12px 15px !important;
  color: #0C2B2B !important;
  font-size: 14px !important;
  box-shadow: none !important;
  transition: border-color .2s, box-shadow .2s, background .2s !important;
}
#wrapwrap .oe_website_login_container .form-control::placeholder {
  color: #9BBEBE !important;
}
#wrapwrap .oe_website_login_container .form-control:focus {
  background: #FDFFFE !important;
  border-color: #13C2C5 !important;
  box-shadow: 0 0 0 3px rgba(19,194,197,.13) !important;
  color: #0C2B2B !important;
  outline: none !important;
}
#wrapwrap .oe_website_login_container .input-group .btn,
#wrapwrap .oe_website_login_container .o_show_password {
  min-height: 48px !important;
  background: #EEF8F8 !important;
  border-color: #D4EDED !important;
  color: #13C2C5 !important;
  border-radius: 0 11px 11px 0 !important;
}

/* ── 11. SUBMIT BUTTON ── */
#wrapwrap .oe_website_login_container .btn-primary {
  min-height: 50px !important;
  border: 0 !important;
  border-radius: 100px !important;
  background: linear-gradient(135deg, #13C2C5 0%, #037C7C 100%) !important;
  color: #fff !important;
  font-weight: 800 !important; font-size: 15px !important;
  letter-spacing: 0.2px !important;
  box-shadow: 0 6px 22px rgba(19,194,197,.3) !important;
  transition: transform .2s, box-shadow .2s !important;
}
#wrapwrap .oe_website_login_container .btn-primary:hover {
  transform: translateY(-2px) !important;
  box-shadow: 0 12px 32px rgba(19,194,197,.4) !important;
}
#wrapwrap .oe_website_login_container .btn-primary:active { transform: translateY(0) !important; }

/* ── 12. SECONDARY BUTTON ── */
#wrapwrap .oe_website_login_container .btn-secondary,
#wrapwrap .oe_website_login_container .btn-outline-secondary {
  min-height: 46px !important;
  border-radius: 100px !important;
  background: #EEF8F8 !important;
  border: 1.5px solid #C2E8E8 !important;
  color: #2A6A6A !important;
  font-size: 14px !important; font-weight: 600 !important;
  transition: background .2s, border-color .2s !important;
}
#wrapwrap .oe_website_login_container .btn-secondary:hover,
#wrapwrap .oe_website_login_container .btn-outline-secondary:hover {
  background: #D6F0F0 !important;
  border-color: #13C2C5 !important;
  color: #037C7C !important;
}

/* ── 13. LINKS ── */
#wrapwrap .oe_website_login_container .btn-link,
#wrapwrap .oe_website_login_container a {
  color: #0D9B9E !important;
  font-weight: 700 !important;
  text-decoration: none !important;
  transition: color .18s !important;
}
#wrapwrap .oe_website_login_container .btn-link:hover,
#wrapwrap .oe_website_login_container a:hover { color: #037C7C !important; }

/* ── 14. ALERTS ── */
#wrapwrap .oe_website_login_container .alert {
  border-radius: 11px !important;
  font-size: 13px !important;
  line-height: 1.55 !important;
  padding: 11px 15px !important;
}
#wrapwrap .oe_website_login_container .alert-danger {
  background: #FEF0F0 !important;
  border: 1.5px solid #F5C5C5 !important;
  color: #9B2020 !important;
}
#wrapwrap .oe_website_login_container .alert-success,
#wrapwrap .oe_website_login_container .alert-info {
  background: #EAF7F7 !important;
  border: 1.5px solid #B2E4E4 !important;
  color: #0A5C5C !important;
}

/* ── 15. BOTTOM SWITCH LINK (Already have an account? / etc.) ── */
#wrapwrap .oe_website_login_container .card-body > .text-center.small {
  border-top: 1.5px solid #EAF3F3 !important;
  color: #7A9E9E !important;
  margin-top: 16px !important;
  padding-top: 16px !important;
  font-size: 13px !important;
}
#wrapwrap .oe_website_login_container .o_login_auth em { color: #7A9E9E !important; }
#wrapwrap .oe_website_login_container .o_login_auth .list-group-item {
  background: #F2FAFA !important;
  border-color: #C8E8E8 !important;
  color: #2A5252 !important;
  border-radius: 10px;
}

/* ── 16. RESPONSIVE ── */
@media (max-width: 540px) {
  #wrapwrap .oe_website_login_container { padding: 24px 14px 40px !important; }
  #wrapwrap .oe_website_login_container .card-body { padding: 24px 18px 20px !important; }
  #wrapwrap .oe_website_login_container .oe_login_form::before,
  #wrapwrap .oe_website_login_container .oe_signup_form::before,
  #wrapwrap .oe_website_login_container .oe_reset_password_form::before { font-size: 20px !important; }
}
</style>

<script>
(function () {
  if (!document.querySelector('.oe_website_login_container')) return;
  var main = document.querySelector('#wrapwrap > main');
  if (main) main.style.setProperty('padding-top', '152px', 'important');
})();
</script>
    </xpath>
  </field>
</record>

</data>
</odoo>
