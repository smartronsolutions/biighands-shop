<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

<record id="bhs_header_view" model="ir.ui.view">
  <field name="name">biighands_shop_website.header</field>
  <field name="key">biighands_shop_website.header</field>
  <field name="inherit_id" ref="website.layout"/>
  <field name="type">qweb</field>
  <field name="arch" type="xml">
    <xpath expr="//header" position="before">

<!-- ── Fetch Odoo ecommerce categories ── -->
<t t-set="bhs_cats" t-value="request.env['product.public.category'].sudo().search(
    [('parent_id', '=', False)],
    order='sequence, name', limit=40
)"/>

<style>
/* ========================================================
   BIIGHANDS — GLOBAL HEADER
   Layout: [Account+Cart] | [Search] | [Logo]
   ======================================================== */
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&amp;display=swap');

/* Hide Odoo default nav / header */
#wrapwrap > header, .o_main_navbar { display: none !important; }

/* Push content below fixed header: 36(ann) + 72(main) + 44(nav) = 152px */
#wrapwrap > main { padding-top: 152px !important; margin-top: 0 !important; }
#wrapwrap > main .bhs-page { padding-top: 0 !important; }
body { overflow-x: hidden; }

/* ── ANNOUNCEMENT BAR ────────────────────────── */
.bhs-ann {
  position: fixed; top: 0; left: 0; right: 0; z-index: 9200;
  height: 36px; background: #071818;
  display: flex; align-items: center; justify-content: center;
  border-bottom: 1px solid rgba(19,194,197,.12);
}
.bhs-ann-items {
  display: flex; align-items: center; gap: 0;
  overflow: hidden;
}
.bhs-ann-item {
  display: flex; align-items: center; gap: 6px;
  font-size: 11.5px; font-weight: 600; color: rgba(255,255,255,.75);
  font-family: 'Inter', sans-serif; white-space: nowrap;
  padding: 0 18px; border-right: 1px solid rgba(255,255,255,.08);
}
.bhs-ann-item:last-child { border-right: none; }
.bhs-ann-item b { color: #AEEBEC; }
.bhs-ann-x {
  position: absolute; right: 14px;
  background: none; border: none; cursor: pointer;
  color: rgba(255,255,255,.35); font-size: 15px; padding: 0 4px;
  transition: color .2s; line-height: 1;
}
.bhs-ann-x:hover { color: rgba(255,255,255,.8); }

/* ── MAIN HEADER ─────────────────────────────── */
.bhs-hdr {
  position: fixed; top: 36px; left: 0; right: 0; z-index: 9199;
  height: 72px; background: #080E0E;
  border-bottom: 1px solid rgba(19,194,197,.1);
  display: flex; align-items: center;
  padding: 0 28px; gap: 16px;
  transition: box-shadow .3s;
}
.bhs-hdr.scrolled { box-shadow: 0 4px 28px rgba(0,0,0,.45); }

/* LEFT — icons */
.bhs-hdr-left {
  display: flex; align-items: center; gap: 2px; flex-shrink: 0;
}

/* CENTER — search */
.bhs-hdr-search {
  flex: 1; min-width: 0; max-width: 640px;
  margin: 0 auto;
}
.bhs-hdr-search form {
  display: flex; background: #fff; border-radius: 8px;
  overflow: hidden; border: 2.5px solid transparent;
  transition: border-color .2s, box-shadow .2s;
}
.bhs-hdr-search form:focus-within {
  border-color: #13C2C5;
  box-shadow: 0 0 0 3px rgba(19,194,197,.2);
}
.bhs-hdr-search input {
  flex: 1; min-width: 0; border: none; outline: none;
  padding: 0 16px; height: 44px; font-size: 14px;
  font-family: 'Inter', sans-serif; color: #111;
  background: transparent;
}
.bhs-hdr-search input::placeholder { color: #9CA3AF; }
.bhs-hdr-search button {
  background: #13C2C5; border: none; cursor: pointer; flex-shrink: 0;
  padding: 0 20px; height: 44px; display: flex; align-items: center;
  transition: background .2s;
}
.bhs-hdr-search button:hover { background: #037C7C; }

/* RIGHT — logo */
.bhs-hdr-logo {
  text-decoration: none !important; flex-shrink: 0;
  display: flex; align-items: center;
}
.bhs-hdr-logo-txt {
  font-family: 'Inter', sans-serif; font-size: 23px;
  font-weight: 900; color: #fff; letter-spacing: -1px; line-height: 1;
}
.bhs-hdr-logo-txt em { color: #13C2C5; font-style: normal; }
.bhs-hdr-logo img { height: 40px; width: auto; display: block; }

/* Icon buttons */
.bhs-hic {
  position: relative; display: flex; flex-direction: column;
  align-items: center; justify-content: center; gap: 2px;
  padding: 8px 10px; border-radius: 8px; cursor: pointer;
  background: transparent; border: none;
  color: rgba(255,255,255,.75) !important;
  text-decoration: none !important;
  transition: all .18s; font-family: 'Inter', sans-serif;
  min-width: 50px;
}
.bhs-hic:hover { background: rgba(255,255,255,.07); color: #13C2C5 !important; }
.bhs-hic-lbl { font-size: 10px; font-weight: 600; white-space: nowrap; }

/* Cart badge */
.bhs-cart-badge {
  position: absolute; top: 3px; right: 6px;
  background: #13C2C5; color: #fff;
  font-size: 9.5px; font-weight: 900; min-width: 17px; height: 17px;
  border-radius: 9px; display: none; align-items: center;
  justify-content: center; padding: 0 4px; line-height: 1;
}

/* Account dropdown */
.bhs-acc { position: relative; }
.bhs-acc-drop {
  position: absolute; top: calc(100% + 10px); left: 0;
  min-width: 215px;
  background: #0C1818; border: 1px solid rgba(19,194,197,.22);
  border-radius: 14px; padding: 8px;
  box-shadow: 0 20px 56px rgba(0,0,0,.55);
  opacity: 0; visibility: hidden; transform: translateY(-8px);
  transition: all .2s; z-index: 9300;
}
.bhs-acc-drop.open {
  opacity: 1; visibility: visible; transform: translateY(0);
}
.bhs-acc-cta {
  background: linear-gradient(135deg, #0D2B2B, #063636);
  border-radius: 10px; padding: 14px; margin-bottom: 6px; text-align: center;
}
.bhs-acc-cta p {
  font-size: 11.5px; color: rgba(255,255,255,.5); margin: 0 0 10px;
  font-family: 'Inter', sans-serif; line-height: 1.5;
}
.bhs-acc-cta .ac-solid {
  display: block; background: #13C2C5; color: #fff !important;
  font-size: 13px; font-weight: 800; padding: 9px; border-radius: 8px;
  text-align: center; text-decoration: none !important; margin-bottom: 6px;
  transition: background .2s;
}
.bhs-acc-cta .ac-solid:hover { background: #037C7C !important; }
.bhs-acc-cta .ac-out {
  display: block; border: 1px solid rgba(19,194,197,.4);
  color: #13C2C5 !important; font-size: 13px; font-weight: 700;
  padding: 8px; border-radius: 8px; text-align: center;
  text-decoration: none !important; transition: all .2s;
}
.bhs-acc-cta .ac-out:hover { background: rgba(19,194,197,.1) !important; }
.bhs-acc-drop a {
  display: flex; align-items: center; gap: 10px;
  padding: 10px 12px; border-radius: 8px; font-size: 13px;
  color: rgba(255,255,255,.75) !important; text-decoration: none !important;
  transition: all .15s; font-family: 'Inter', sans-serif;
}
.bhs-acc-drop a:hover { background: rgba(19,194,197,.1); color: #13C2C5 !important; }
.bhs-acc-sep { height: 1px; background: rgba(255,255,255,.07); margin: 5px 2px; }

/* Hamburger */
.bhs-ham {
  display: none; flex-direction: column; gap: 5px;
  align-items: center; justify-content: center;
  background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1);
  padding: 9px 10px; border-radius: 8px; cursor: pointer;
  width: 42px; height: 42px; flex-shrink: 0;
}
.bhs-ham span {
  display: block; width: 20px; height: 2px;
  background: rgba(255,255,255,.75); border-radius: 2px; transition: all .3s;
}
.bhs-ham.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.bhs-ham.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
.bhs-ham.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

/* ── CATEGORY NAV STRIP ──────────────────────── */
.bhs-nav {
  position: fixed; top: 108px; left: 0; right: 0; z-index: 9198;
  height: 44px; background: #13C2C5;
  display: flex; align-items: stretch;
}
.bhs-nav-inner {
  width: 100%; max-width: 1440px; margin: 0 auto;
  display: flex; align-items: stretch; padding: 0 28px;
}

/* All Departments wrapper + mega dropdown */
.bhs-alldep {
  position: static;
}
.bhs-alldep-btn {
  display: flex; align-items: center; gap: 8px;
  padding: 0 20px; height: 44px;
  background: rgba(0,0,0,.18); border: none; cursor: pointer;
  font-size: 13px; font-weight: 800; color: #fff;
  font-family: 'Inter', sans-serif; white-space: nowrap;
  border-right: 1px solid rgba(255,255,255,.18);
  transition: background .2s;
}
.bhs-alldep-btn:hover, .bhs-alldep:hover .bhs-alldep-btn {
  background: rgba(0,0,0,.32);
}
.bhs-alldep-btn .chevron {
  transition: transform .2s;
}
.bhs-alldep:hover .bhs-alldep-btn .chevron { transform: rotate(180deg); }

/* Mega dropdown */
.bhs-mega {
  position: fixed; top: 152px; left: 0; right: 0;
  background: #0B1616; border-top: 2px solid #13C2C5;
  border-bottom: 1px solid rgba(19,194,197,.15);
  padding: 28px 40px 32px;
  box-shadow: 0 24px 60px rgba(0,0,0,.55);
  opacity: 0; visibility: hidden; transform: translateY(-6px);
  transition: opacity .22s, visibility .22s, transform .22s;
  z-index: 9197;
  max-height: calc(100vh - 160px); overflow-y: auto;
}
.bhs-alldep:hover .bhs-mega { opacity: 1; visibility: visible; transform: translateY(0); }
.bhs-mega:hover { opacity: 1; visibility: visible; transform: translateY(0); }

.bhs-mega-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
  gap: 4px 24px;
  max-width: 1200px;
}
.bhs-mega-col { padding: 0; }
.bhs-mega-parent {
  display: block; padding: 8px 12px 6px;
  font-size: 13px; font-weight: 800; color: #fff !important;
  text-decoration: none !important; border-radius: 7px;
  transition: all .15s; border-bottom: 1px solid rgba(19,194,197,.12);
  margin-bottom: 4px;
}
.bhs-mega-parent:hover { background: rgba(19,194,197,.12); color: #13C2C5 !important; }
.bhs-mega-child {
  display: block; padding: 5px 12px;
  font-size: 12px; font-weight: 500; color: rgba(255,255,255,.6) !important;
  text-decoration: none !important; border-radius: 6px; transition: all .15s;
}
.bhs-mega-child:hover { background: rgba(19,194,197,.08); color: #13C2C5 !important; }
.bhs-mega-viewall {
  display: inline-flex; align-items: center; gap: 6px; margin-top: 20px;
  color: #13C2C5 !important; font-size: 13px; font-weight: 700;
  text-decoration: none !important; padding: 8px 16px;
  border: 1px solid rgba(19,194,197,.35); border-radius: 7px;
  transition: all .2s;
}
.bhs-mega-viewall:hover { background: rgba(19,194,197,.12); }

/* Category nav links */
.bhs-nav-links {
  display: flex; align-items: stretch; flex: 1; overflow-x: auto;
  scrollbar-width: none;
}
.bhs-nav-links::-webkit-scrollbar { display: none; }
.bhs-nav-links a {
  display: flex; align-items: center;
  padding: 0 14px; font-size: 13px; font-weight: 600;
  color: rgba(255,255,255,.9) !important; text-decoration: none !important;
  white-space: nowrap; transition: background .16s;
  border-right: 1px solid rgba(255,255,255,.1);
}
.bhs-nav-links a:hover { background: rgba(255,255,255,.16); color: #fff !important; }
.bhs-nav-links a.act { background: rgba(255,255,255,.2); color: #fff !important; font-weight: 800; }
.bhs-nav-end {
  display: flex; align-items: stretch; margin-left: auto;
  border-left: 1px solid rgba(255,255,255,.18);
}
.bhs-nav-end a {
  display: flex; align-items: center; gap: 5px;
  padding: 0 14px; font-size: 12px; font-weight: 700;
  color: rgba(255,255,255,.9) !important; text-decoration: none !important;
  white-space: nowrap; transition: background .16s;
}
.bhs-nav-end a:hover { background: rgba(0,0,0,.15); color: #fff !important; }

/* ── MOBILE DRAWER ───────────────────────────── */
.bhs-mob {
  position: fixed; top: 108px; left: 0; right: 0; bottom: 0;
  z-index: 9400; background: #080E0E;
  transform: translateX(-100%);
  transition: transform .34s cubic-bezier(.4,0,.2,1);
  overflow-y: auto; padding-bottom: 80px;
}
.bhs-mob.open { transform: translateX(0); }
.bhs-mob-head {
  padding: 16px 18px; background: #0D1F1F;
  border-bottom: 1px solid rgba(19,194,197,.12);
}
.bhs-mob-head form {
  display: flex; background: #fff; border-radius: 8px; overflow: hidden;
}
.bhs-mob-head input {
  flex: 1; border: none; outline: none; padding: 12px 14px;
  font-size: 14px; font-family: 'Inter', sans-serif; min-width: 0;
}
.bhs-mob-head button {
  background: #13C2C5; border: none; padding: 0 16px; cursor: pointer;
  display: flex; align-items: center;
}
.bhs-mob-btns { padding: 14px 18px; display: flex; gap: 10px; }
.bhs-mob-btn {
  flex: 1; text-align: center; padding: 13px 10px;
  border-radius: 10px; font-size: 14px; font-weight: 800;
  text-decoration: none !important; font-family: 'Inter', sans-serif;
  transition: all .2s;
}
.bhs-mob-btn.tc { background: #13C2C5; color: #fff !important; }
.bhs-mob-btn.tc:hover { background: #037C7C; }
.bhs-mob-btn.ot {
  background: transparent; color: #13C2C5 !important;
  border: 1.5px solid rgba(19,194,197,.35);
}
.bhs-mob-btn.ot:hover { background: rgba(19,194,197,.08); }
.bhs-mob-sec {
  padding: 12px 18px 4px; font-size: 10px; font-weight: 800;
  letter-spacing: 2px; text-transform: uppercase;
  color: rgba(255,255,255,.22); font-family: 'Inter', sans-serif;
}
.bhs-mob-div { height: 1px; background: rgba(255,255,255,.06); margin: 4px 0; }
.bhs-mob-list { list-style: none; padding: 0; margin: 0; }
.bhs-mob-list li a {
  display: flex; align-items: center; gap: 12px;
  padding: 13px 18px; font-size: 14.5px; font-weight: 500;
  color: rgba(255,255,255,.75) !important; text-decoration: none !important;
  border-bottom: 1px solid rgba(255,255,255,.04);
  font-family: 'Inter', sans-serif; transition: color .15s;
}
.bhs-mob-list li a:hover { color: #13C2C5 !important; }
.bhs-mob-list li a .ic { font-size: 17px; width: 22px; text-align: center; flex-shrink: 0; }

/* ── RESPONSIVE ──────────────────────────────── */
@media (max-width: 1100px) {
  .bhs-hdr { padding: 0 18px; gap: 12px; }
  .bhs-nav-inner { padding: 0 18px; }
}
@media (max-width: 900px) {
  .bhs-nav { display: none; }
  #wrapwrap > main { padding-top: 108px !important; }
  .bhs-mob { top: 108px; }
  .bhs-ham { display: flex !important; }
  .bhs-hic-lbl { display: none; }
  .bhs-hic { min-width: auto; padding: 8px; }
}
@media (max-width: 600px) {
  .bhs-hdr { padding: 0 12px; gap: 8px; }
}
@media (max-width: 440px) {
  .bhs-ann { display: none; }
  .bhs-hdr { top: 0; }
  .bhs-nav { top: 72px; }
  .bhs-mob { top: 72px; }
  #wrapwrap > main { padding-top: 116px !important; }
}
</style>

<!-- ══ ANNOUNCEMENT BAR ══════════════════════════════ -->
<div class="bhs-ann" id="bhsAnn">
  <div class="bhs-ann-items">
    <div class="bhs-ann-item">🚚 <span><b>FREE DELIVERY</b> on orders over $50</span></div>
    <div class="bhs-ann-item">📦 <span>Click &amp; Collect — <b>Ready in 1 Hour</b></span></div>
    <div class="bhs-ann-item">⚡ <span>Same Day Dispatch <b>before 3pm</b></span></div>
    <div class="bhs-ann-item" style="border-right:none">🏷️ <span><b>Trade Accounts</b> — Exclusive Pricing</span></div>
  </div>
  <button class="bhs-ann-x" id="bhsAnnX" type="button">&#10005;</button>
</div>

<!-- ══ MAIN HEADER ════════════════════════════════════ -->
<header class="bhs-hdr" id="bhsHdr" role="banner">

  <!-- LEFT: Account + Cart + Ham -->
  <div class="bhs-hdr-left">

    <!-- Account -->
    <div class="bhs-acc" id="bhsAcc">
      <button class="bhs-hic" id="bhsAccBtn" type="button" title="Account">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        <span class="bhs-hic-lbl">Account</span>
      </button>
      <div class="bhs-acc-drop" id="bhsAccDrop">
        <t t-if="website.is_public_user()">
          <div class="bhs-acc-cta">
            <p>Sign in for faster checkout,<br/>orders &amp; trade pricing</p>
            <a href="/web/login" class="ac-solid">Sign In</a>
            <a href="/web/signup" class="ac-out">Create Account</a>
          </div>
        </t>
        <t t-if="not website.is_public_user()">
          <a href="/my/home">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
            My Account
          </a>
          <a href="/my/orders">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
            My Orders
          </a>
          <a href="/my/invoices">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            Invoices
          </a>
          <div class="bhs-acc-sep"></div>
          <a href="/web/session/logout">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            Logout
          </a>
        </t>
      </div>
    </div>

    <!-- Cart -->
    <a href="/shop/cart" class="bhs-hic" id="bhsCart" title="Cart">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
      <span class="bhs-cart-badge" id="bhsCartN">0</span>
      <span class="bhs-hic-lbl">Cart</span>
    </a>

    <!-- Hamburger (mobile only) -->
    <button class="bhs-ham" id="bhsHam" type="button" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>

  </div>

  <!-- CENTER: Search -->
  <div class="bhs-hdr-search">
    <form action="/shop" method="get" role="search">
      <input type="text" name="search"
        placeholder="Search 10,000+ products..."
        autocomplete="off" aria-label="Search"/>
      <button type="submit" aria-label="Search">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      </button>
    </form>
  </div>

  <!-- RIGHT: Logo -->
  <a href="/home" class="bhs-hdr-logo">
    <span class="bhs-hdr-logo-txt">biig<em>hands</em></span>
  </a>

</header>

<!-- ══ CATEGORY NAV STRIP ═════════════════════════════ -->
<nav class="bhs-nav" id="bhsNav" aria-label="Shop categories">
  <div class="bhs-nav-inner">

    <!-- All Departments + mega dropdown -->
    <div class="bhs-alldep" id="bhsAllDep">
      <button class="bhs-alldep-btn" type="button">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        All Departments
        <svg class="chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
      </button>

      <!-- Mega dropdown -->
      <div class="bhs-mega" id="bhsMega">
        <div class="bhs-mega-grid">
          <t t-if="bhs_cats">
            <t t-foreach="bhs_cats" t-as="bcat">
              <div class="bhs-mega-col">
                <a t-att-href="'/shop?category=%s' % bcat.id" class="bhs-mega-parent">
                  <t t-esc="bcat.name"/>
                </a>
                <t t-foreach="bcat.child_id" t-as="sub">
                  <a t-att-href="'/shop?category=%s' % sub.id" class="bhs-mega-child">
                    <t t-esc="sub.name"/>
                  </a>
                </t>
              </div>
            </t>
          </t>
          <t t-if="not bhs_cats">
            <div style="color:rgba(255,255,255,.5);font-size:13px;padding:8px 12px;">
              No categories yet — add them in Odoo eCommerce.
            </div>
          </t>
        </div>
