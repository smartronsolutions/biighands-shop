<!-- ══ JAVASCRIPT ═════════════════════════════════════ -->
<script>
(function () {
  "use strict";

  var ann    = document.getElementById('bhsAnn');
  var annX   = document.getElementById('bhsAnnX');
  var hdr    = document.getElementById('bhsHdr');
  var nav    = document.getElementById('bhsNav');
  var mob    = document.getElementById('bhsMob');
  var ham    = document.getElementById('bhsHam');
  var acc    = document.getElementById('bhsAcc');
  var accBtn = document.getElementById('bhsAccBtn');
  var accDrp = document.getElementById('bhsAccDrop');
  var allDep = document.getElementById('bhsAllDep');

  /* Announcement close */
  if (annX) {
    annX.addEventListener('click', function () {
      if (ann) { ann.style.display = 'none'; }
      if (hdr) { hdr.style.top = '0'; }
      if (nav) { nav.style.top = '72px'; }
      if (mob) { mob.style.top = '72px'; }
      document.documentElement.style.setProperty('--bhs-main-top', '72px');
      var m = document.querySelector('#wrapwrap > main');
      if (m) m.style.paddingTop = '116px';
    });
  }

  /* Scroll shadow */
  if (hdr) {
    window.addEventListener('scroll', function () {
      hdr.classList.toggle('scrolled', window.scrollY > 30);
    }, { passive: true });
  }

  /* Hamburger + mobile drawer */
  if (ham &amp;&amp; mob) {
    ham.addEventListener('click', function () {
      var o = mob.classList.toggle('open');
      ham.classList.toggle('open', o);
      mob.setAttribute('aria-hidden', String(!o));
      document.body.style.overflow = o ? 'hidden' : '';
    });
    mob.querySelectorAll('a').forEach(function (a) {
      a.addEventListener('click', function () {
        mob.classList.remove('open');
        ham.classList.remove('open');
        mob.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      });
    });
  }

  /* Account dropdown */
  if (accBtn &amp;&amp; accDrp) {
    accBtn.addEventListener('click', function (e) {
      e.stopPropagation();
      accDrp.classList.toggle('open');
    });
    document.addEventListener('click', function (e) {
      if (acc &amp;&amp; !acc.contains(e.target)) {
        accDrp.classList.remove('open');
      }
    });
  }

  /* Cart badge — reads Odoo's hidden cart quantity span */
  function syncCart () {
    var el = document.getElementById('bhsCartN');
    if (!el) return;
    var src = document.querySelector('.my_cart_quantity');
    var n = src ? (parseInt(src.textContent) || 0) : 0;
    el.textContent = n;
    el.style.display = n > 0 ? 'flex' : 'none';
  }
  syncCart();
  setTimeout(syncCart, 600);
  setTimeout(syncCart, 1500);
  document.addEventListener('odoo.product.cart.update', syncCart);

  /* Active category highlight */
  var qs = window.location.search;
  var catMatch = qs.match(/[?&amp;]category=(\d+)/);
  if (catMatch) {
    var catId = catMatch[1];
    document.querySelectorAll('.bhs-nav-links a').forEach(function (a) {
      if (a.href.indexOf('category=' + catId) !== -1) {
        a.classList.add('act');
      }
    });
  }

})();
</script>

