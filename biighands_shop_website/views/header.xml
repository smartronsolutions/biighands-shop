<!-- ══ HEADER JAVASCRIPT ══════════════════════════════ -->
<script>
(function () {
  "use strict";

  var ann     = document.getElementById('bhsAnn');
  var annCls  = document.getElementById('bhsAnnClose');
  var hdr     = document.getElementById('bhsHeader');
  var nav     = document.getElementById('bhsNav');
  var ham     = document.getElementById('bhsHam');
  var mob     = document.getElementById('bhsMob');
  var accBtn  = document.getElementById('bhsAccBtn');
  var accDrop = document.getElementById('bhsAccDrop');
  var accWrap = document.getElementById('bhsAcc');

  /* ── Announcement close ── */
  if (annCls) {
    annCls.addEventListener('click', function () {
      if (ann) ann.style.display = 'none';
      if (hdr) hdr.style.top = '0';
      if (nav) nav.style.top = '72px';
    });
  }

  /* ── Scroll shadow ── */
  if (hdr) {
    window.addEventListener('scroll', function () {
      hdr.classList.toggle('scrolled', window.scrollY > 40);
    }, { passive: true });
  }

  /* ── Hamburger ── */
  if (ham &amp;&amp; mob) {
    ham.addEventListener('click', function () {
      var open = mob.classList.toggle('open');
      ham.classList.toggle('open', open);
      mob.setAttribute('aria-hidden', String(!open));
      document.body.style.overflow = open ? 'hidden' : '';
    });
    mob.querySelectorAll('a').forEach(function (a) {
      a.addEventListener('click', function () {
        mob.classList.remove('open');
        ham.classList.remove('open');
        mob.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      });
    });
  }

  /* ── Account dropdown ── */
  if (accBtn &amp;&amp; accDrop) {
    accBtn.addEventListener('click', function (e) {
      e.stopPropagation();
      accDrop.classList.toggle('open');
    });
    document.addEventListener('click', function (e) {
      if (accWrap &amp;&amp; !accWrap.contains(e.target)) {
        accDrop.classList.remove('open');
      }
    });
  }

  /* ── Cart badge: read from Odoo cart quantity ── */
  function updateCart () {
    var el = document.getElementById('bhsCartCount');
    if (!el) return;
    var badge = document.querySelector('.my_cart_quantity');
    if (badge) {
      var n = parseInt(badge.textContent) || 0;
      el.textContent = n;
      el.style.display = n > 0 ? 'flex' : 'none';
    }
  }
  setTimeout(updateCart, 800);
  document.addEventListener('odoo.product.cart.update', updateCart);

  /* ── Active nav highlight ── */
  var path = window.location.pathname;
  document.querySelectorAll('.bhs-h-nav-links a').forEach(function (a) {
    if (a.getAttribute('href') === path) {
      a.style.background = 'rgba(255,255,255,.22)';
      a.style.color = '#fff';
    }
  });

})();
</script>

