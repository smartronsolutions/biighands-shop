<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
    ============================================================================
    Dynamic Snippet Preview
    ============================================================================
    -->
    <template id="tp_preview_body" name="Preview: Body">
        <t t-call="web.frontend_layout">
            <t t-set="no_header" t-value="True"/>
            <t t-set="no_footer" t-value="True"/>
            <t t-set="no_livechat" t-value="True"/>
            <t t-if="mobile">
                <div class="d-flex text-center justify-content-between p-2 w-100 px-3">
                    <div class="small fw-bold" t-out="datetime.datetime.now().strftime('%H:%M')"/>
                    <div class="small">
                        <i style="font-size:14px;" class="fa fa-wifi ms-1"></i>
                        <i style="font-size:14px;" class="fa fa-signal ms-1"></i>
                        <i style="font-size:14px;" class="fa fa-battery-full ms-1"/>
                    </div>
                </div>
                <div class="row g-0 mb-4 pb-2 border-bottom">
                    <div class="p-2 col-2 justify-content-center text-center align-items-center"><i style="font-size:18px;" class="fa text-muted fa-home"/></div>
                    <div class="p-2 col-7 text-truncate" style="background-color: #f7f8fb;border-radius: 40px;"><i class="fa text-muted fa-lock px-2 text-success"></i> <t t-out="request.httprequest.url_root"/></div>
                    <div class="p-2 col-3 justify-content-between d-flex align-items-center"><i style="font-size:18px;" class="fa text-muted fa-plus-square-o ps-2"></i> <i style="font-size:18px;" class="fa fa-ellipsis-v pe-3"></i></div>
                </div>
            </t>
            <div id="tp_wrap"></div>
        </t>
    </template>

    <template id="tp_carousel_only_slider" inherit_id="website_sale.shop_product_images" name="Theme Prime: Product Images Carousel only" primary="True">
        <xpath expr="//t[@t-call='website_sale.shop_product_#{website.product_page_image_layout}']" position="replace">
            <t t-call="website_sale.shop_product_carousel"/>
        </xpath>
    </template>

    <!--
    ============================================================================
    Quick View
    ============================================================================
    -->
    <!-- used main_product_classes in condition at few places it is coming only from snippet -->
    <template id="tp_product_quick_view" name="Product Quick View">
        <t t-set="rtl_class" t-value="request.env['res.lang']._get_data(code=request.env.lang).direction == 'rtl' and 'o_rtl' or ''"/>
        <section id="product_detail"
            t-attf-class="js_sale tp-ignore-compare-banner oe_website_sale container #{'discount' if combination_info['has_discounted_price'] else ''} tp-product-quick-view-layout tp-ignore-variant-change-url #{rtl_class} #{'tp-combo-product' if product.type == 'combo' else ''}"
            t-att-data-view-track="view_track and '1' or '0'"
        >
            <div class="row">
                <div class="col-12 col-lg-6 col-xl-6 py-2 d-flex flex-column">
                    <div id="product_detail_main" data-image_layout="carousel" data-name="Product Page">
                        <t t-call="theme_prime.tp_carousel_only_slider"/>
                    </div>
                    <a t-att-href="product.website_url" class="btn btn-link btn-block mt-2 tp-website-product-link">
                        <i class="fa fa-info-circle me-1"></i> Full Product Information
                    </a>
                </div>
                <div class="col-12 col-lg-6 col-xl-6 py-2" id="product_details">
                    <!-- Label -->
                    <div t-attf-class="js_product js_main_product {{main_product_classes}}">
                        <t t-call="theme_prime.product_label">
                            <t t-set="label" t-value="product.sudo()._get_ribbon(price_vals=combination_info, variant=product_variant)"/>
                            <t t-set="style" t-valuef="1"/>
                            <t t-set="_classes" t-valuef="mb-2 d-inline-block position-relative top-0 start-0"/>
                        </t>
                        <h3 t-field="product.name">Product Name</h3>
                        <div t-if="is_view_active('website_sale.product_comment') or product.get_recent_sold_qty().get(product.id)" class="d-flex align-items-center flex-wrap gap-3 mb-2">
                            <a t-if="is_view_active('website_sale.product_comment')" href="#o_product_page_reviews" class="o_product_page_reviews_link text-decoration-none">
                                <t t-call="portal_rating.rating_widget_stars_static">
                                    <t t-set="rating_avg" t-value="product.sudo().rating_avg"/>
                                    <t t-set="trans_text_plural">%s reviews</t>
                                    <t t-set="trans_text_singular">%s review</t>
                                    <t t-set="rating_count" t-value="(trans_text_plural if product.rating_count > 1 else trans_text_singular) % product.rating_count"/>
                                </t>
                            </a>
                            <h6 class="text-danger d-flex align-items-center mb-0 gap-1" t-if="product.get_recent_sold_qty().get(product.id)">
                                <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" fill="currentColor" class="bi bi-fire" viewBox="0 0 16 16">
                                    <path d="M8 16c3.314 0 6-2 6-5.5 0-1.5-.5-4-2.5-6 .25 1.5-1.25 2-1.25 2C11 4 9 .5 6 0c.357 2 .5 4-2 6-1.25 1-2 2.729-2 4.5C2 14 4.686 16 8 16m0-1c-1.657 0-3-1-3-2.75 0-.75.25-2 1.25-3C6.125 10 7 10.5 7 10.5c-.375-1.25.5-3.25 2-3.5-.179 1-.25 2 1 3 .625.5 1 1.364 1 2.25C11 14 9.657 15 8 15"/>
                                </svg>
                                <span><t t-out="product.get_recent_sold_qty().get(product.id)"/> sold in last <t t-out="website._get_dr_theme_config('json_product_recent_sales').get('duration', 24)"/> hours</span>
                            </h6>
                        </div>
                        <t t-set="is_add_to_cart_possible" t-value="product._is_add_to_cart_possible()"/>
                        <div t-field="product.description_ecommerce" t-attf-class="oe_structure text-muted {{not product.description_ecommerce and 'mb-0' or 'mb-2'}}"/>
                        <p t-if="(not is_add_to_cart_possible) and (not product.active)" class="alert alert-warning">
                            This product is no longer available.
                        </p>
                        <p t-elif="not is_add_to_cart_possible" class="alert alert-warning">
                            This product has no valid combination.
                        </p>
                        <form t-if="is_add_to_cart_possible">
                            <div class="mb-4">
                                <t t-call="theme_prime.product_price"/>
                                <small t-if="combination_info.get('base_unit_price')"
                                    class="ms-1 text-muted o_base_unit_price_wrapper d-none">
                                    <t t-call="website_sale.base_unit_price">
                                        <t
                                            t-set="base_unit_price"
                                            t-value="combination_info['base_unit_price']"
                                        />
                                    </t>
                                </small>
                            </div>
                            <input
                                type="hidden"
                                name="csrf_token"
                                t-att-value="request.csrf_token()"
                            />

                            <t name="variant_info">
                                <input
                                    type="hidden"
                                    class="o_not_editable product_id"
                                    name="product_id"
                                    t-att-value="product_variant.id"
                                />
                                <input
                                    type="hidden"
                                    class="o_not_editable product_template_id"
                                    name="product_template_id"
                                    t-att-value="product.id"
                                />
                                <input
                                    t-if="product.public_categ_ids.ids"
                                    type="hidden"
                                    class="product_category_id"
                                    name="product_category_id"
                                    t-att-value="product.public_categ_ids.ids[0]"
                                />
                                <input
                                    type="hidden"
                                    name="product_type"
                                    t-att-value="product.type"
                                />
                                <div
                                    t-attf-class="mb-4 {{not (product.valid_product_template_attribute_line_ids or product._has_multiple_uoms()) and 'd-none' or ' '}}"
                                >
                                    <t t-call="website_sale.variants">
                                        <t t-set="ul_class" t-valuef="flex-column" />
                                        <t t-set="parent_combination" t-value="None" />
                                        <t
                                            t-set="combination"
                                            t-value="combination_info['combination']"
                                        />
                                    </t>
                                </div>
                            </t>
                            <div class="availability_messages o_not_editable"/>
                            <input id="wsale_user_email" type="hidden" t-att-value="user_email"/>
                            <div id="o_wsale_cta_wrapper" class="d-flex flex-wrap align-items-center gap-2 my-2">
                                <t t-call="theme_prime.tp_quantity_multiplier_input_group"/>
                                <div
                                    id="add_to_cart_wrap"
                                    t-attf-class="{{'d-none' if combination_info['prevent_zero_price_sale'] else 'd-flex'}} flex-grow-1 flex-lg-grow-0 flex-wrap align-items-center gap-2"
                                >
                                    <a id="add_to_cart" role="button" href="#" t-attf-class="btn btn-primary btn-lg js_check_product a-submit flex-grow-1 px-5" t-att-data-show-quantity="is_view_active('website_sale.product_quantity')" data-animation-selector=".o_wsale_product_images">
                                        <i class="dri dri-cart me-1"/>
                                        Add to Cart
                                    </a>
                                    <a t-if="is_view_active('website_sale.product_buy_now') and main_product_classes" role="button" class="btn btn-primary-soft btn-lg o_we_buy_now" href="#">
                                        <i class="dri dri-bolt me-1"/> Buy Now
                                    </a>
                                </div>
                                <div id="product_option_block" class="d-flex d-empty-none flex-wrap gap-3" style="flex-basis: 100%;">
                                    <t t-set="product_variant" t-value="product_variant or product._create_first_product_variant()"/>
                                    <t t-set="in_wish" t-value="product_variant and product_variant._is_in_wishlist()"/>
                                    <a
                                        t-if="product_variant"
                                        class="btn btn-link px-0 o_add_wishlist_dyn"
                                        t-att-disabled="in_wish"
                                        t-att-data-product-template-id="product.id"
                                        t-att-data-product-variant-id="product_variant.id"
                                        data-action="o_wishlist"
                                        title="Add to wishlist"
                                    >
                                        <i class="fa fa-heart-o me-1" role="img" aria-label="Add to wishlist"/> Add to wishlist
                                    </a>
                                </div>
                            </div>
                        </form>
                        <div
                            id="contact_us_wrapper"
                            t-attf-class="{{'d-flex' if combination_info['prevent_zero_price_sale'] else 'd-none'}} oe_structure oe_structure_solo #{_div_classes}"
                        >
                            <section
                                class="s_text_block"
                                data-snippet="s_text_block"
                                data-name="Text">
                                <div class="container">
                                    <a
                                        t-att-href="website.contact_us_button_url"
                                        t-att-data-url="website.contact_us_button_url"
                                        class="btn btn-primary btn_cta"
                                    >
                                        Contact Us
                                    </a>
                                </div>
                            </section>
                        </div>
                        <div class="d-flex flex-column row-gap-3">
                            <!-- Brand -->
                            <div class="d-flex align-items-center gap-3" t-if="product.dr_brand_value_id">
                                <div t-if="product.dr_brand_value_id.image" t-field="product.with_context(show_attribute=False).dr_brand_value_id.image" t-options="{'widget': 'image', 'qweb_img_responsive': False, 'class': 'border rounded object-fit-contain', 'width': 80, 'height': 80}"/>
                                <div>
                                    <h6>
                                        <a class="tp-link-dark" t-attf-href="/shop?attribute_values=#{product.dr_brand_value_id.attribute_id.id}-#{product.dr_brand_value_id.id}">
                                            <span t-field="product.dr_brand_value_id.name"/>
                                        </a>
                                    </h6>
                                    <p class="mb-0" t-field="product.dr_brand_value_id.dr_brand_description"/>
                                </div>
                            </div>
                            <!-- Extra fields -->
                            <t t-call="theme_prime.product_extra_fields" />
                        </div>
                        <t t-if="main_product_classes">
                            <h6 class="mt-3 mb-0 tp-hover-color-primary">
                                <a t-att-href="product.website_url">
                                    View Full Details <i class="fa ms-1 fa-angle-right"/>
                                </a>
                            </h6>
                        </t>
                    </div>
                </div>
            </div>
        </section>
    </template>

    <!--
    ============================================================================
    Right Panel only (TO-DO) use existing quick view template
    ============================================================================
    -->
    <template id="tp_product_right_panel">
        <t t-set="rtl_class" t-value="request.env['res.lang']._get_data(code=request.env.lang).direction == 'rtl' and 'o_rtl' or ''"/>

        <section t-att-data-product-tracking-info="'product_tracking_info' in combination_info and json.dumps(combination_info['product_tracking_info'])" t-att-data-product-tmpl-id="product.id" t-attf-class="#{'auto-add-product' if auto_add_product else '' } #{'tp-combo-product' if product.type == 'combo' else ''} container px-0 o_not_editable oe_website_sale tp-product-variant-selector-layout tp-ignore-variant-change-url #{rtl_class}">
            <div id="product_detail_main" class="d-none" t-att-data-image_width="website.product_page_image_width" t-att-data-image_layout="website.product_page_image_layout">
                <t t-call="theme_prime.tp_carousel_only_slider"/>
            </div>
            <div id="product_details">
                <h2 class="tp-hover-color-primary m-0 mb-2 mt-2 text-truncate">
                    <a t-att-href="product.website_url">
                        <span t-field="product.name"/>
                    </a>
                </h2>
                <t t-if="is_view_active('website_sale.product_comment')">
                    <t t-call="portal_rating.rating_widget_stars_static">
                        <t t-set="rating_avg" t-value="product.sudo().rating_avg"/>
                        <t t-set="trans_text_plural">%s reviews</t>
                        <t t-set="trans_text_singular">%s review</t>
                        <t t-set="rating_count" t-value="(trans_text_plural if product.rating_count > 1 else trans_text_singular) % product.rating_count"/>
                    </t>
                </t>
                <p t-field="product.description_ecommerce" class="mt-3 text-muted" placeholder="A short description that will also appear on documents." />

                <t if="product.type == 'combo' and product.combo_ids">
                    <div class="row g-2">
                        <t t-foreach="product.sudo().combo_ids" t-as="_combo">
                            <div class="col-4" t-if="_combo.combo_item_ids">
                                <div class="card h-100 d-flex">
                                    <div class="d-flex align-items-center" style="flex-grow:1;">
                                        <div style="width: 67%;padding-right: 0.12rem;">
                                            <img style="max-height: 376px; object-fit:contain;" loading="lazy" t-attf-src="/web/image/product.product/#{_combo.combo_item_ids[0].product_id.id}/image_512" class="d-block w-100"/>
                                        </div>
                                        <div style="width: 33%;padding-left: 0.12rem;">
                                            <img t-if="len(_combo.combo_item_ids) > 1" style="max-height: 188px; object-fit:contain;" loading="lazy" t-attf-src="/web/image/product.product/#{_combo.combo_item_ids[1].product_id.id}/image_512" class="d-block w-100 pb-1"/>
                                            <img t-if="len(_combo.combo_item_ids) > 2"  style="max-height: 188px; object-fit:contain;" loading="lazy" t-attf-src="/web/image/product.product/#{_combo.combo_item_ids[2].product_id.id}/image_512" class="d-block w-100"/>
                                        </div>
                                    </div>
                                    <div class="card-body py-2 px-1" style="flex-grow:0;">
                                        <h6 class="text-center mb-0" t-out="_combo.name"/>
                                        <p class="text-center small mb-0 text-muted">
                                            <t t-out="len(_combo.combo_item_ids)"></t> Options
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </div>
                </t>
                <input id="wsale_user_email" type="hidden" t-att-value="user_email"/>
                <form t-if="product._is_add_to_cart_possible()" class="d_cart_update_form" action="/shop/cart/update" method="POST">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()" />
                    <div class="js_product js_main_product">
                        <div>
                            <t t-call="theme_prime.product_price"/>
                            <small t-if="'base_unit_price' in combination_info" class="o_base_unit_price_wrapper d-none" groups="website_sale.group_show_uom_price">
                                <t t-call='website_sale.base_unit_price'/>
                            </small>
                        </div>
                        <hr name="after_price"/>
                        <t t-placeholder="select">
                            <input type="hidden" class="product_id" name="product_id" t-att-value="product_variant.id" />
                            <input type="hidden" class="product_template_id" name="product_template_id" t-att-value="product.id" />
                            <input t-if="product.public_categ_ids.ids" type="hidden" class="product_category_id" name="product_category_id" t-att-value="product.public_categ_ids.ids[0]" />
                            <t t-call="website_sale.variants">
                                <t t-set="ul_class" t-valuef="flex-column" />
                                <t t-set="parent_combination" t-value="None" />
                                <t t-set="combination" t-value="combination_info['combination']"/>
                            </t>
                        </t>
                        <!-- [TO-DO]: check when combination doesn't exists -->
                        <p t-if="True" class="css_not_available_msg d-none alert alert-warning mt-2">This combination does not exist.</p>
                        <div class="availability_messages o_not_editable my-3"/>
                        <div id="o_wsale_cta_wrapper" class="d-flex flex-column align-items-center mt-3">
                            <t t-call="theme_prime.tp_quantity_multiplier_input_group"/>
                            <div id="contact_us_wrapper" t-if="combination_info['prevent_zero_price_sale']">
                                <a t-att-href="website.contact_us_button_url" class="btn btn-primary btn-lg btn_cta mt-2">Contact Us</a>
                            </div>
                            <div id="add_to_cart_wrap" class="w-100" t-else="">
                                <a role="button" id="add_to_cart" class="btn w-100 btn-primary btn-lg js_check_product a-submit mt-2" href="#">
                                    <i class="dri dri-cart me-1"/> Add to Cart
                                </a>
                            </div>
                        </div>
                    </div>
                </form>
                <p t-elif="not product.active" class="alert alert-warning">This product is no longer available.</p>
                <p t-else="" class="alert alert-warning">This product has no valid combination.</p>
            </div>
        </section>
    </template>

    <!--
    ============================================================================
    Product Variant Selector Dialog
    ============================================================================
    -->
    <template id="product_variant_selector_dialog" name="Product Variant Selector Dialog">
        <t t-set="rtl_class" t-value="request.env['res.lang']._get_data(code=request.env.lang).direction == 'rtl' and 'o_rtl' or ''"/>
        <section id="product_detail"
            t-att-data-product-tmpl-id="product.id"
            t-attf-class="oe_website_sale container px-0 tp-product-quick-view-layout tp-ignore-variant-change-url #{rtl_class} #{'auto-add-product' if auto_add_product else '' } #{'tp-combo-product' if product.type == 'combo' else ''} #{'tp-product-out-of-stock' if not product.allow_out_of_stock_order and product.is_storable and product.dr_free_qty &lt;= 0 else ''}"
            t-att-data-view-track="view_track and '1' or '0'"
            t-att-data-product-tracking-info="'product_tracking_info' in combination_info and json.dumps(combination_info['product_tracking_info'])"
            >
            <div id="product_detail_main" class="px-0" t-att-data-image_width="website.product_page_image_width" t-att-data-image_layout="website.product_page_image_layout">
                <t t-call="theme_prime.tp_carousel_only_slider"/>
            </div>
            <hr/>
            <div id="product_details" class="px-0 w-100">
                <h4 itemprop="name" t-field="product.name">Product Name</h4>
                <input id="wsale_user_email" type="hidden" t-att-value="user_email"/>
                <form t-if="product._is_add_to_cart_possible()" action="/shop/cart/update" method="POST">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    <div class="js_product js_main_product">
                        <div>
                            <t t-call="theme_prime.product_price"/>
                            <small t-if="'base_unit_price' in combination_info"
                                    class="ms-1 text-muted o_base_unit_price_wrapper d-none" groups="website_sale.group_show_uom_price">
                                <t t-call='website_sale.base_unit_price'/>
                            </small>
                        </div>
                        <hr name="after_price"/>
                        <t t-placeholder="select">
                            <input type="hidden" class="product_id" name="product_id" t-att-value="product_variant.id" />
                            <input type="hidden" class="product_template_id" name="product_template_id" t-att-value="product.id" />
                            <input t-if="product.public_categ_ids.ids" type="hidden" class="product_category_id" name="product_category_id" t-att-value="product.public_categ_ids.ids[0]" />
                            <t t-call="website_sale.variants">
                                <t t-set="ul_class" t-valuef="flex-column" />
                                <t t-set="parent_combination" t-value="None" />
                                <t t-set="combination" t-value="combination_info['combination']"/>
                            </t>
                        </t>
                        <p t-if="True" class="css_not_available_msg alert alert-warning">This combination does not exist.</p>
                        <div class="availability_messages o_not_editable mt-2"/>
                        <div id="o_wsale_cta_wrapper" class="d-flex flex-column align-items-center mt-3">
                            <t t-call="theme_prime.tp_quantity_multiplier_input_group"/>
                            <div id="add_to_cart_wrap" t-attf-class="{{'d-none' if combination_info['prevent_zero_price_sale'] else 'd-inline-flex'}} align-items-center mt-3 w-100">
                                <a data-animation-selector=".product_detail_img" role="button" id="add_to_cart" class="btn btn-primary btn-lg js_check_product py-3 a-submit flex-grow-1 rounded-0" href="#">
                                    <i class="dri dri-cart me-1"/> Add to Cart
                                </a>
                                <a t-if="is_view_active('website_sale.product_buy_now')" role="button" class="btn btn-primary-soft py-3 btn-lg o_we_buy_now rounded-0" href="#">
                                    <i class="dri dri-bolt me-1"/> Buy Now
                                </a>
                            </div>
                        </div>
                        <div id="contact_us_wrapper"
                                t-attf-class="{{'my-3 justify-content-center' if combination_info['prevent_zero_price_sale'] else 'd-none'}} oe_structure oe_structure_solo #{_div_classes}">
                            <section class="s_text_block" data-snippet="s_text_block" data-name="Text">
                                <div class="container">
                                    <a t-att-href="website.contact_us_button_url"
                                        class="btn btn-primary btn_cta w-100">Contact Us
                                    </a>
                                </div>
                            </section>
                        </div>
                    </div>
                </form>
                <p t-elif="not product.active" class="alert alert-warning">This product is no longer available.</p>
                <p t-else="" class="alert alert-warning">This product has no valid combination.</p>
            </div>
        </section>
    </template>

</odoo>
