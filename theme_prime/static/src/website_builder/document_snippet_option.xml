<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="theme_prime.DocumentSnippetOption">
        <BuilderRow label.translate="Document">
            <BuilderButton action="'addDocument'">Add New</BuilderButton>
        </BuilderRow>
    </t>

    <t t-name="theme_prime.DocumentElement">
        <div class="col-12 col-sm-6 col-md-4 col-lg-3 my-2">
            <div class="d-flex align-items-center p-2 border rounded">
                <div class="o_image flex-shrink-0" t-att-data-mimetype="document.mimetype"/>
                <div class="ms-2 text-truncate">
                    <div t-out="document.name" t-att-title="document.name"/>
                    <a t-att-href="document.url" class="link-primary">
                        <i class="fa fa-download"/> Download
                    </a>
                </div>
            </div>
        </div>
    </t>

    <t t-name="theme_prime.ShowProductVariantImage">
        <BuilderRow label.translate="Show Product Variant Image">
            <BuilderCheckbox classAction="'tp-show-variant-image'"/>
        </BuilderRow>
    </t>

</templates>
