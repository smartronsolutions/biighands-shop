<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="theme_prime.HeaderNavigationOption" t-inherit="website.HeaderNavigationOption" t-inherit-mode="extension">
        <t t-set="align_left_views" position="after">
            <t t-set="align_left_views" t-value="[
                ...align_left_views,
                'theme_prime.template_header_style_1_align_start',
                'theme_prime.template_header_style_5_align_start',
            ]"/>
        </t>
        <t t-set="align_center_views" position="after">
            <t t-set="align_center_views" t-value="[
                ...align_center_views,
                'theme_prime.template_header_style_1_align_center',
                'theme_prime.template_header_style_2_align_center',
                'theme_prime.template_header_style_3_align_center',
                'theme_prime.template_header_style_4_align_center',
                'theme_prime.template_header_style_6_align_center',
                'theme_prime.template_header_style_7_align_center',
                'theme_prime.template_header_style_8_align_center',
            ]"/>
        </t>
        <t t-set="align_right_views" position="after">
            <t t-set="align_right_views" t-value="[
                ...align_right_views,
                'theme_prime.template_header_style_2_align_right',
                'theme_prime.template_header_style_3_align_right',
                'theme_prime.template_header_style_4_align_right',
                'theme_prime.template_header_style_5_align_right',
                'theme_prime.template_header_style_6_align_right',
                'theme_prime.template_header_style_7_align_right',
                'theme_prime.template_header_style_8_align_right',
            ]"/>
        </t>

        <BuilderRow label.translate="Mobile Menu" position="replace">
            <BuilderRow label.translate="Mobile Menu">
                <BuilderButtonGroup action="'websiteConfig'">
                    <BuilderButton icon="'fa-long-arrow-left'"
                        actionParam="{
                            views: ['website.template_header_mobile_position_left', 'theme_prime.template_header_mobile_position_left'],
                            vars: { 'hamburger-position-mobile': 'left' }
                        }"/>
                    <BuilderButton
                        icon="'fa-long-arrow-right'"
                        actionParam="{
                            views: [],
                            vars: { 'hamburger-position-mobile': 'right' }
                        }"/>
                </BuilderButtonGroup>

                <BuilderSelect action="'websiteConfig'">
                    <BuilderSelectItem
                        actionParam="{
                            views: [],
                        }"
                    >
                        <span><i class="fa fa-align-left fa-fw"></i></span>
                    </BuilderSelectItem>
                    <BuilderSelectItem
                        actionParam="{
                            views: ['website.template_header_mobile_align_center', 'theme_prime.template_header_mobile_align_center'],
                        }"
                    >
                        <span><i class="fa fa-align-center fa-fw"></i></span>
                    </BuilderSelectItem>
                    <BuilderSelectItem
                        actionParam="{
                            views: ['website.template_header_mobile_align_right', 'theme_prime.template_header_mobile_align_right'],
                        }"
                    >
                        <span><i class="fa fa-align-right fa-fw"></i></span>
                    </BuilderSelectItem>
                </BuilderSelect>
            </BuilderRow>
        </BuilderRow>
    </t>

</templates>
